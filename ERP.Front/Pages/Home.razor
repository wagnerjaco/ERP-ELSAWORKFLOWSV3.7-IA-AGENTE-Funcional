@page "/"
@inject CategoriasService CategoriasService
@inject MarcasService MarcasService
@inject FornecedoresService FornecedoresService
@inject ProdutosService ProdutosService
@inject PedidoComprasService PedidoComprasService
@inject NavigationManager Navigation
@inject WinBoxService WinBoxService
<PageTitle>Dashboard - ERP</PageTitle>

<div class="dashboard-page">
    <div class="page-header">
        <div class="header-content">
            <h1 class="page-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                Dashboard
            </h1>
            <p class="page-subtitle">Visão geral do seu sistema ERP</p>
        </div>
        <div class="header-date">
            <span class="date-badge">@DateTime.Now.ToString("dd/MM/yyyy")</span>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="loading-container">
            <div class="spinner-large"></div>
            <p>Carregando dados...</p>
        </div>
    }
    else
    {
        <div class="stats-grid">
            <div class="stat-card stat-categorias" @onclick=Categorias>
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@categorias.Count</span>
                    <span class="stat-label">Categorias</span>
                </div>
                <div class="stat-trend stat-up">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                </div>
            </div>

            <div class="stat-card stat-marcas" @onclick=Marcas>
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@marcas.Count</span>
                    <span class="stat-label">Marcas</span>
                </div>
                <div class="stat-trend stat-up">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                </div>
            </div>

            <div class="stat-card stat-fornecedores" @onclick=Fornecedores>
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@fornecedores.Count</span>
                    <span class="stat-label">Fornecedores</span>
                </div>
                <div class="stat-trend stat-up">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                </div>
            </div>

            <div class="stat-card stat-produtos" @onclick=Produtos>
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@produtos.Count</span>
                    <span class="stat-label">Produtos</span>
                </div>
                <div class="stat-trend stat-up">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                </div>
            </div>

            <div class="stat-card stat-pedidos" @onclick=PedidosCompras>
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@pedidos.Count</span>
                    <span class="stat-label">Pedidos Compra</span>
                </div>
                <div class="stat-trend stat-up">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                </div>
            </div>
        </div>
        <div class="dashboard-grid">
            <div class="dashboard-card card-chart">
                <div class="card-header">
                    <h3 class="card-title">Distribuição por Tipo</h3>
                    <span class="card-subtitle">Produtos por categoria de tipo</span>
                </div>
                <div class="chart-wrapper">
                    <div class="chart-content">
                        <div class="donut-chart-large">
                            <svg viewBox="0 0 100 100" class="donut">
                                @{
                                    var tipos = produtos.GroupBy(p => p.Tipo).ToList();
                                    var cores = new string[] { "#3b82f6", "#10b981", "#8b5cf6", "#f59e0b", "#06b6d4" };
                                    double offset = 62.83;
                                    for (int i = 0; i < tipos.Count; i++)
                                    {
                                        var pct = tipos[i].Count() * 100.0 / (produtos.Count > 0 ? produtos.Count : 1);
                                        var dash = pct * 2.51327;
                                        <circle cx="50" cy="50" r="40" fill="none" stroke="@cores[i]" stroke-width="10" stroke-dasharray="@dash 251.327" stroke-dashoffset="@offset" />
                                        offset -= dash;
                                    }
                                }
                            </svg>
                            <div class="chart-center">
                                <span class="chart-total">@produtos.Count</span>
                                <span class="chart-label">Total</span>
                            </div>
                        </div>
                        @{
                            var grupos = produtos.GroupBy(p => p.Tipo).ToList();
                            var u = 0;
                        }

                        <div class="chart-legend">
                            @foreach (var grupo in grupos)
                            {
                                <div class="legend-item">
                                    <span class="legend-color" style="background: @cores[u % cores.Count()];"></span>
                                    <span class="legend-text">@GetTipoLabel(grupo.Key)</span>
                                    <span class="legend-value">@grupo.Count()</span>
                                </div>

                                u++;
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="dashboard-card card-status">
                <div class="card-header">
                    <h3 class="card-title">Status de Produtos</h3>
                    <span class="card-subtitle">Situação atual do catálogo</span>
                </div>
                <div class="status-list">
                    @foreach (var situacao in produtos.GroupBy(p => p.Situacao).OrderByDescending(g => g.Count()))
                    {
                        <div class="status-item">
                            <div class="status-info">
                                <span class="status-badge" style="background: @GetSituacaoColor(situacao.Key)20; color: @GetSituacaoColor(situacao.Key);">
                                    @GetSituacaoLabel(situacao.Key)
                                </span>
                                <span class="status-percent">@((situacao.Count() * 100.0 / (produtos.Count > 0 ? produtos.Count : 1)).ToString("F1"))%</span>
                            </div>
                            <div class="status-bar">
                                <div class="status-fill" style="width: @((situacao.Count() * 100.0 / (produtos.Count > 0 ? produtos.Count : 1)))%; background: @GetSituacaoColor(situacao.Key);"></div>
                            </div>
                            <span class="status-count">@situacao.Count()</span>
                        </div>
                    }
                </div>
            </div>

            <div class="dashboard-card card-summary">
                <div class="card-header">
                    <h3 class="card-title">Resumo Financeiro</h3>
                    <span class="card-subtitle">Valores do catálogo</span>
                </div>
                <div class="summary-grid">
                    <div class="summary-item">
                        <span class="summary-label">Preço Médio Venda</span>
                        <span class="summary-value">@((produtos.Count > 0 ? produtos.Average(p => p.PrecoVenda) : 0).ToString("C2"))</span>
                    </div>
                    <div class="summary-item">
                        <span class="summary-label">Preço Médio Custo</span>
                        <span class="summary-value">@((produtos.Count > 0 ? produtos.Average(p => p.CustoMedio) : 0).ToString("C2"))</span>
                    </div>
                    <div class="summary-item">
                        <span class="summary-label">Maior Preço</span>
                        <span class="summary-value">@((produtos.Count > 0 ? produtos.Max(p => p.PrecoVenda) : 0).ToString("C2"))</span>
                    </div>
                    <div class="summary-item">
                        <span class="summary-label">Menor Preço</span>
                        <span class="summary-value">@((produtos.Count > 0 ? produtos.Min(p => p.PrecoVenda) : 0).ToString("C2"))</span>
                    </div>
                </div>
            </div>

            <div class="dashboard-card card-recent">
                <div class="card-header">
                    <h3 class="card-title">Cadastros Recentes</h3>
                    <span class="card-subtitle">Últimos registros</span>
                </div>
                <div class="recent-list">
                    @foreach (var item in GetRecentItems().Take(8))
                    {
                        <div class="recent-item" @onclick="() => NavigateTo(item.Item2)">
                            <div class="recent-icon" style="background: @item.Item3; color: white;">
                                @item.Item4
                            </div>
                            <div class="recent-content">
                                <span class="recent-name">@item.Item1</span>
                                <span class="recent-type">@item.Item5</span>
                            </div>
                            <span class="recent-arrow">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                            </span>
                        </div>
                    }
                </div>
            </div>

            <div class="dashboard-card card-fornecedores">
                <div class="card-header">
                    <h3 class="card-title">Fornecedores por Tipo</h3>
                    <span class="card-subtitle">Pessoa física e jurídica</span>
                </div>
                <div class="tipo-pessoa-chart">
                    <div class="tipo-item">
                        <div class="tipo-circle" style="background: conic-gradient(#8b5cf6 0deg @GetPessoaDeg(fornecedores.Count(f => f.TipoPessoa == TipoPessoa.FISICA), fornecedores.Count) 360deg);">
                            <span class="tipo-value">@fornecedores.Count(f => f.TipoPessoa == TipoPessoa.FISICA)</span>
                        </div>
                        <span class="tipo-label">Pessoa Física</span>
                    </div>
                    <div class="tipo-item">
                        <div class="tipo-circle" style="background: conic-gradient(#06b6d4 0deg @GetPessoaDeg(fornecedores.Count(f => f.TipoPessoa == TipoPessoa.JURIDICA), fornecedores.Count) 360deg);">
                            <span class="tipo-value">@fornecedores.Count(f => f.TipoPessoa == TipoPessoa.JURIDICA)</span>
                        </div>
                        <span class="tipo-label">Pessoa Jurídica</span>
                    </div>
                </div>
            </div>

            <div class="dashboard-card card-quick-links">
                <div class="card-header">
                    <h3 class="card-title">Ações Rápidas</h3>
                </div>
                <div class="quick-links">
                    <button class="quick-link" @onclick=CategoriasNova>
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        <span>Nova Categoria</span>
                    </button>
                    <button class="quick-link" @onclick=MarcasNova>
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        <span>Nova Marca</span>
                    </button>
                    <button class="quick-link" @onclick=FornecedoresNovo>
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        <span>Novo Fornecedor</span>
                    </button>
                    <button class="quick-link" @onclick=ProdutosNovo>
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        <span>Novo Produto</span>
                    </button>
                </div>
            </div>
        </div>
    }
</div>
@code {
    private List<Categoria> categorias = new();
    private List<Marca> marcas = new();
    private List<Fornecedor> fornecedores = new();
    private List<Produto> produtos = new();
    private List<PedidoCompra> pedidos = new();
    private bool isLoading = true;
    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }
    private async Task CarregarDados()
    {
        isLoading = true;
        try
        {
            var taskCategorias = CategoriasService.GetAllAsync();
            var taskMarcas = MarcasService.GetAllAsync();
            var taskFornecedores = FornecedoresService.GetAllAsync();
            var taskProdutos = ProdutosService.GetAllAsync();
            var taskPedidos = PedidoComprasService.GetAllAsync();

            await Task.WhenAll(taskCategorias, taskMarcas, taskFornecedores, taskProdutos, taskPedidos);

            categorias = await taskCategorias;
            marcas = await taskMarcas;
            fornecedores = await taskFornecedores;
            produtos = await taskProdutos;
            pedidos = await taskPedidos;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar dados: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private List<(string, string, string, char, string)> GetRecentItems()
    {
        var items = new List<(string, string, string, char, string)>();

        foreach (var c in categorias.OrderByDescending(c => c.CreatedAt).Take(2))
            items.Add((c.Nome, "categorias", "#3b82f6", 'C', "Categoria"));

        foreach (var m in marcas.OrderByDescending(m => m.CreatedAt).Take(2))
            items.Add((m.Nome, "marcas", "#8b5cf6", 'M', "Marca"));

        foreach (var f in fornecedores.OrderByDescending(f => f.CreatedAt).Take(2))
            items.Add((f.Nome, "fornecedores", "#06b6d4", 'F', "Fornecedor"));

        foreach (var p in produtos.OrderByDescending(p => p.CreatedAt).Take(2))
            items.Add((p.Descricao, "produtos", "#10b981", 'P', "Produto"));

        return items.OrderByDescending(i => i.Item5).ToList();
    }

    private async Task NavigateTo(string page)
    {
        await WinBoxService.OpenWindow(page, GetPageTitle(page), $"/{page}", 1000, 700);
    }
    
    private string GetPageTitle(string page) => page switch
    {
        "categorias" => "Categorias",
        "marcas" => "Marcas",
        "produtos" => "Produtos",
        "fornecedores" => "Fornecedores",
        _ => page
    };

    private async Task Produtos()
    {
        await WinBoxService.OpenWindow("produtos", "Produtos", "/produtos", 1000, 700);
    }
    private async Task Categorias()
    {
        await WinBoxService.OpenWindow("categorias", "Categorias", "/categorias", 1000, 700);
    }
    private async Task Marcas()
    {
        await WinBoxService.OpenWindow("marcas", "Marcas", "/marcas", 1000, 700);
    }
    private async Task Fornecedores()
    {
        await WinBoxService.OpenWindow("fornecedores", "Fornecedores", "/fornecedores", 1000, 700);
    }
    private async Task PedidosCompras()
    {
        await WinBoxService.OpenWindow("pedidosCompras", "Pedidos de Compra", "/pedidoscompras", 1000, 700);
    }
    private async Task ProdutosNovo()
    {
        await WinBoxService.OpenWindow("produto-edit-nova", "Novo Produto", "/produtos/novo", 800, 700);
    }
    private async Task CategoriasNova()
    {
        await WinBoxService.OpenWindow("categoria-edit-nova", "Nova Categoria", "/categorias/nova", 600, 500);
    }
    private async Task MarcasNova()
    {
        await WinBoxService.OpenWindow("marca-edit-nova", "Nova Marca", "/marcas/nova", 600, 500);
    }
    private async Task FornecedoresNovo()
    {
        await WinBoxService.OpenWindow("fornecedor-edit-nova", "Novo Fornecedor", "/fornecedores/novo", 700, 600);
    }
    private async Task PedidosComprasNovo()
    {
        await WinBoxService.OpenWindow("pedidosCompras-edit-nova", "Novo Pedido de Compra", "/pedidoscompras/nova", 800, 700);
    }

    
    private string GetTipoLabel(TipoProduto tipo) => tipo switch
    {
        TipoProduto.MERCADORIA => "Mercadoria",
        TipoProduto.MATERIA_PRIMA => "Mat. Prima",
        TipoProduto.PRODUTO_ACABADO => "Prod. Acabado",
        TipoProduto.EMBALAGEM => "Embalagem",
        TipoProduto.USO_CONSUMO => "Uso Consumo",
        _ => "-"
    };

    private string GetSituacaoLabel(SituacaoProduto situacao) => situacao switch
    {
        SituacaoProduto.ATIVO => "Ativo",
        SituacaoProduto.INATIVO => "Inativo",
        SituacaoProduto.RASCUNHO => "Rascunho",
        SituacaoProduto.AGUARDANDO_FISCAL => "Aguard. Fiscal",
        SituacaoProduto.AGUARDANDO_PCP => "Aguard. PCP",
        SituacaoProduto.PENDENTE_APROVACAO => "Pendente",
        _ => "-"
    };

    private string GetSituacaoColor(SituacaoProduto situacao) => situacao switch
    {
        SituacaoProduto.ATIVO => "#10b981",
        SituacaoProduto.INATIVO => "#6b7280",
        SituacaoProduto.RASCUNHO => "#f59e0b",
        SituacaoProduto.AGUARDANDO_FISCAL => "#8b5cf6",
        SituacaoProduto.AGUARDANDO_PCP => "#06b6d4",
        SituacaoProduto.PENDENTE_APROVACAO => "#ec4899",
        _ => "#6b7280"
    };

    private double GetPessoaDeg(int count, int total)
    {
        if (total == 0) return 0;
        return count * 360.0 / total;
    }
}