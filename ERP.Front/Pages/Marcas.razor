@page "/marcas"
@inject MarcasService MarcasService
@inject NavigationManager Navigation
@inject WinBoxService WinBoxService

<PageTitle>Marcas - ERP</PageTitle>

<div class="marcas-page window-content">
    <div class="page-header">
        <div class="header-content">
            <h1 class="page-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                Marcas
            </h1>
            <p class="page-subtitle">Gerencie as marcas dos seus produtos</p>
        </div>
        <button class="btn btn-primary btn-new" @onclick="NovaMarca">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Nova Marca
        </button>
    </div>

    @if (isLoading)
    {
        <div class="loading-container">
            <div class="spinner-large"></div>
            <p>Carregando marcas...</p>
        </div>
    }
    else
    {
        <div class="stats-grid">
            <div class="stat-card stat-primary">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@marcas.Count</span>
                    <span class="stat-label">Total de Marcas</span>
                </div>
            </div>
            <div class="stat-card stat-success">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@marcas.Count(m => m.Ativa)</span>
                    <span class="stat-label">Ativas</span>
                </div>
            </div>
            <div class="stat-card stat-warning">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@marcas.Count(m => !m.Ativa)</span>
                    <span class="stat-label">Inativas</span>
                </div>
            </div>
            <div class="stat-card stat-info">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@marcas.Count(m => !string.IsNullOrEmpty(m.Descricao))</span>
                    <span class="stat-label">Com Descricao</span>
                </div>
            </div>
        </div>

        <div class="content-grid">
            <div class="chart-section">
                <div class="chart-card">
                    <h3 class="chart-title">Status das Marcas</h3>
                    <div class="chart-container">
                        <div class="donut-chart">
                            <svg viewBox="0 0 100 100" class="donut">
                                @{
                                    var ativasCount = marcas.Count(m => m.Ativa);
                                    var inativasCount = marcas.Count(m => !m.Ativa);
                                    var total = marcas.Count;
                                    if (total > 0)
                                    {
                                        var ativasPct = ativasCount * 100.0 / total;
                                        var inativasPct = inativasCount * 100.0 / total;
                                        var ativasDash = ativasPct * 2.51327;
                                        <circle cx="50" cy="50" r="40" fill="none" stroke="#10b981" stroke-width="12" stroke-dasharray="@ativasDash 251.327" stroke-dashoffset="62.83" />
                                        <circle cx="50" cy="50" r="40" fill="none" stroke="#f59e0b" stroke-width="12" stroke-dasharray="@inativasPct 251.327" stroke-dashoffset="@(62.83 - ativasDash)" />
                                    }
                                }
                            </svg>
                            <div class="chart-center">
                                <span class="chart-total">@marcas.Count</span>
                                <span class="chart-label">Total</span>
                            </div>
                        </div>
                        <div class="chart-legend">
                            <div class="legend-item">
                                <span class="legend-color" style="background: #10b981;"></span>
                                <span class="legend-text">Ativas</span>
                                <span class="legend-value">@marcas.Count(m => m.Ativa)</span>
                            </div>
                            <div class="legend-item">
                                <span class="legend-color" style="background: #f59e0b;"></span>
                                <span class="legend-text">Inativas</span>
                                <span class="legend-value">@marcas.Count(m => !m.Ativa)</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="recent-card">
                    <h3 class="chart-title">Recentemente Adicionadas</h3>
                    <div class="recent-list">
                        @foreach (var marca in marcas.OrderByDescending(m => m.CreatedAt).Take(6))
                        {
                            <div class="recent-item marca-item">
                                <div class="marca-avatar" style="background: @GetMarcaColor(marca.Nome)">
                                    @marca.Nome.Substring(0, 1).ToUpper()
                                </div>
                                <div class="recent-content">
                                    <span class="recent-name">@marca.Nome</span>
                                    <span class="recent-date">@marca.CreatedAt.ToString("dd/MM/yyyy")</span>
                                </div>
                                <span class="recent-badge" style="background: @(marca.Ativa ? "#10b981" : "#f59e0b")20; color: @(marca.Ativa ? "#10b981" : "#f59e0b");">
                                    @(marca.Ativa ? "Ativa" : "Inativa")
                                </span>
                            </div>
                        }
                        @if (!marcas.Any())
                        {
                            <div class="empty-state">
                                <p>Nenhuma marca cadastrada</p>
                            </div>
                        }
                    </div>
                </div>

                <div class="chart-card">
                    <h3 class="chart-title">Nuvem de Marcas</h3>
                    <div class="tag-cloud">
                        @foreach (var marca in marcas.OrderBy(m => m.Nome))
                        {
                            <span class="tag-item" style="font-size: @(GetTagSize(marca.Nome)); color: @GetMarcaColor(marca.Nome);">
                                @marca.Nome
                            </span>
                        }
                        @if (!marcas.Any())
                        {
                            <div class="empty-state">
                                <p>Nenhuma marca para exibir</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="table-section">
                <div class="table-card">
                    <div class="table-header">
                        <h3 class="table-title">Todas as Marcas</h3>
                        <div class="table-search">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                            <input type="text" placeholder="Buscar marca..." @bind="searchTerm" @oninput="OnSearch" />
                        </div>
                    </div>
                    <div class="table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Marca</th>
                                    <th>Descricao</th>
                                    <th>Status</th>
                                    <th>Data Cadastro</th>
                                    <th>Acoes</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var marca in filteredMarcas)
                                {
                                    <tr>
                                        <td>
                                            <div class="cell-name">
                                                <div class="name-icon" style="background: @GetMarcaColor(marca.Nome); color: white;">
                                                    @marca.Nome.Substring(0, 1).ToUpper()
                                                </div>
                                                @marca.Nome
                                            </div>
                                        </td>
                                        <td class="cell-desc">
                                            @(string.IsNullOrEmpty(marca.Descricao) ? "-" : marca.Descricao)
                                        </td>
                                        <td>
                                            <span class="status-badge @(marca.Ativa ? "status-active" : "status-inactive")">
                                                @(marca.Ativa ? "Ativa" : "Inativa")
                                            </span>
                                        </td>
                                        <td class="cell-date">
                                            @marca.CreatedAt.ToString("dd/MM/yyyy")
                                        </td>
                                        <td>
                                            <div class="action-buttons">
                                                <button class="btn-action btn-edit" @onclick="() => EditarMarca(marca)" title="Editar">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                                </button>
                                                <button class="btn-action btn-delete" @onclick="() => ConfirmarDelete(marca)" title="Excluir">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                @if (!filteredMarcas.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="empty-row">
                                            <div class="empty-table">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
                                                <p>Nenhuma marca encontrada</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (showDeleteModal)
    {
        <div class="modal-overlay" @onclick="CancelarDelete">
            <div class="modal-content" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h3>Confirmar Exclusao</h3>
                    <button class="modal-close" @onclick="CancelarDelete">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </div>
                <div class="modal-body">
                    <p>Tem certeza que deseja excluir a marca "<strong>@marcaParaExcluir?.Nome</strong>"?</p>
                    <p class="warning-text">Esta acao tornara a marca inativa.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelarDelete">Cancelar</button>
                    <button class="btn btn-danger" @onclick="ExcluirMarca">Excluir</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Marca> marcas = new();
    private List<Marca> filteredMarcas = new();
    private bool isLoading = true;
    private string searchTerm = string.Empty;
    private bool showDeleteModal = false;
    private Marca? marcaParaExcluir;

    private readonly string[] brandColors = { "#3b82f6", "#10b981", "#8b5cf6", "#f59e0b", "#ef4444", "#06b6d4", "#ec4899", "#84cc16" };

    protected override async Task OnInitializedAsync()
    {
        await CarregarMarcas();
    }

    private async Task CarregarMarcas()
    {
        isLoading = true;
        try
        {
            marcas = await MarcasService.GetAllAsync();
            filteredMarcas = marcas;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar marcas: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnSearch()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredMarcas = marcas;
        }
        else
        {
            filteredMarcas = marcas.Where(m =>
                m.Nome.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                (m.Descricao?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
            ).ToList();
        }
    }

    private async Task NovaMarca()
    {
        await WinBoxService.OpenWindow("marca-edit-nova", "Nova Marca", "/marcas/nova", 600, 500);
    }

    private async Task EditarMarca(Marca marca)
    {
        await WinBoxService.OpenWindow($"marca-edit-{marca.Id}", "Editar Marca", $"/marcas/{marca.Id}", 600, 500);
    }

    private void ConfirmarDelete(Marca marca)
    {
        marcaParaExcluir = marca;
        showDeleteModal = true;
    }

    private void CancelarDelete()
    {
        showDeleteModal = false;
        marcaParaExcluir = null;
    }

    private async Task ExcluirMarca()
    {
        if (marcaParaExcluir != null)
        {
            try
            {
                await MarcasService.DeleteAsync(marcaParaExcluir.Id);
                await CarregarMarcas();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Erro ao excluir marca: {ex.Message}");
            }
        }
        showDeleteModal = false;
        marcaParaExcluir = null;
    }

    private string GetMarcaColor(string nome)
    {
        var index = nome.GetHashCode() % brandColors.Length;
        if (index < 0) index += brandColors.Length;
        return brandColors[index];
    }

    private string GetTagSize(string nome)
    {
        var length = nome.Length;
        if (length <= 5) return "1rem";
        if (length <= 10) return "1.1rem";
        if (length <= 15) return "1.2rem";
        return "1.3rem";
    }
}