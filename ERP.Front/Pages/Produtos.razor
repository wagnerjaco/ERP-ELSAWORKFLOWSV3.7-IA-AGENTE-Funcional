@page "/produtos"
@using ERP.Front.Models
@inject ProdutosService ProdutosService
@inject NavigationManager Navigation
@inject WinBoxService WinBoxService

<PageTitle>Produtos - ERP</PageTitle>

<div class="produtos-page window-content">
    <div class="page-header">
        <div class="header-content">
            <h1 class="page-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                Produtos
            </h1>
            <p class="page-subtitle">Gerencie o catalogo de produtos</p>
        </div>
        <button class="btn btn-primary btn-new" @onclick="NovoProduto">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Novo Produto
        </button>
    </div>

    @if (isLoading)
    {
        <div class="loading-container">
            <div class="spinner-large"></div>
            <p>Carregando produtos...</p>
        </div>
    }
    else
    {
        <div class="stats-grid">
            <div class="stat-card stat-primary">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@produtos.Count</span>
                    <span class="stat-label">Total de Produtos</span>
                </div>
            </div>
            <div class="stat-card stat-success">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@produtos.Count(p => p.Situacao == SituacaoProduto.ATIVO)</span>
                    <span class="stat-label">Ativos</span>
                </div>
            </div>
            <div class="stat-card stat-info">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@produtos.Sum(p => p.PrecoVenda).ToString("C2")</span>
                    <span class="stat-label">Valor Total Estoque</span>
                </div>
            </div>
            <div class="stat-card stat-warning">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@produtos.Count(p => p.Situacao == SituacaoProduto.RASCUNHO)</span>
                    <span class="stat-label">Rascunhos</span>
                </div>
            </div>
        </div>

        <div class="content-grid">
            <div class="chart-section">
                <div class="chart-card">
                    <h3 class="chart-title">Por Tipo</h3>
                    <div class="chart-container">
                        <div class="donut-chart">
                            <svg viewBox="0 0 100 100" class="donut">
                                @{
                                    var tipos = produtos.GroupBy(p => p.Tipo).ToList();
                                    var cores = new string[] { "#3b82f6", "#10b981", "#8b5cf6", "#f59e0b", "#06b6d4" };
                                    double offset = 62.83;
                                    int i = 0;
                                    foreach (var grupo in tipos)
                                    {
                                        var pct = grupo.Count() * 100.0 / produtos.Count;
                                        var dash = pct * 2.51327;
                                        <circle cx="50" cy="50" r="40" fill="none" stroke="@cores[i % 5]" stroke-width="10" stroke-dasharray="@dash 251.327" stroke-dashoffset="@offset" />
                                        offset -= dash;
                                        i++;
                                    }
                                }
                            </svg>
                            <div class="chart-center">
                                <span class="chart-total">@produtos.Count</span>
                                <span class="chart-label">Total</span>
                            </div>
                        </div>
                        <div class="chart-legend">
                            @foreach (var grupo in tipos)
                            {
                                <div class="legend-item">
                                    <span class="legend-color" style="background: @cores[tipos.IndexOf(grupo) % 5];"></span>
                                    <span class="legend-text">@GetTipoLabel(grupo.Key)</span>
                                    <span class="legend-value">@grupo.Count()</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="chart-card">
                    <h3 class="chart-title">Por Situacao</h3>
                    <div class="situacao-list">
                        @foreach (var situacao in produtos.GroupBy(p => p.Situacao).OrderByDescending(g => g.Count()))
                        {
                            <div class="situacao-item">
                                <span class="situacao-badge" style="background: @GetSituacaoColor(situacao.Key)20; color: @GetSituacaoColor(situacao.Key);">
                                    @GetSituacaoLabel(situacao.Key)
                                </span>
                                <div class="situacao-bar">
                                    <div class="situacao-fill" style="width: @(produtos.Count > 0 ? (situacao.Count() * 100.0 / produtos.Count) : 0)%; background: @GetSituacaoColor(situacao.Key);"></div>
                                </div>
                                <span class="situacao-count">@situacao.Count()</span>
                            </div>
                        }
                    </div>
                </div>

                <div class="recent-card">
                    <h3 class="chart-title">Produtos Recentes</h3>
                    <div class="recent-list">
                        @foreach (var produto in produtos.OrderByDescending(p => p.CreatedAt).Take(5))
                        {
                            <div class="recent-item produto-item">
                                <div class="produto-icon" style="background: @GetTipoColor(produto.Tipo)20; color: @GetTipoColor(produto.Tipo);">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                                </div>
                                <div class="recent-content">
                                    <span class="recent-name">@produto.Descricao</span>
                                    <span class="recent-date">@produto.CreatedAt.ToString("dd/MM/yyyy") - @produto.PrecoVenda.ToString("C2")</span>
                                </div>
                                <span class="recent-badge" style="background: @GetSituacaoColor(produto.Situacao)20; color: @GetSituacaoColor(produto.Situacao);">
                                    @GetSituacaoLabel(produto.Situacao)
                                </span>
                            </div>
                        }
                        @if (!produtos.Any())
                        {
                            <div class="empty-state">
                                <p>Nenhum produto cadastrado</p>
                            </div>
                        }
                    </div>
                </div>

                <div class="chart-card">
                    <h3 class="chart-title">Top 5 Marcas</h3>
                    <div class="marca-list">
                        @foreach (var marca in produtos.Where(p => p.Marca != null).GroupBy(p => p.Marca!.Nome).OrderByDescending(g => g.Count()).Take(5))
                        {
                            <div class="marca-item">
                                <span class="marca-rank">#@(produtos.Where(p => p.Marca != null).GroupBy(p => p.Marca!.Nome).OrderByDescending(g => g.Count()).ToList().IndexOf(marca) + 1)</span>
                                <span class="marca-nome">@marca.Key</span>
                                <span class="marca-count">@marca.Count() produtos</span>
                            </div>
                        }
                        @if (!produtos.Any(p => p.Marca != null))
                        {
                            <div class="empty-state">
                                <p>Nenhum produto com marca</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="table-section">
                <div class="table-card">
                    <div class="table-header">
                        <h3 class="table-title">Catalogo de Produtos</h3>
                        <div class="table-search">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                            <input type="text" placeholder="Buscar produto..." @bind="searchTerm" @oninput="OnSearch" />
                        </div>
                    </div>
                    <div class="table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>SKU</th>
                                    <th>Produto</th>
                                    <th>Tipo</th>
                                    <th>Marca</th>
                                    <th>Custo</th>
                                    <th>Venda</th>
                                    <th>Status</th>
                                    <th>Acoes</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var produto in filteredProdutos)
                                {
                                    <tr>
                                        <td class="cell-sku">@produto.Sku</td>
                                        <td>
                                            <div class="cell-name">
                                                <div class="name-icon" style="background: @GetTipoColor(produto.Tipo)20; color: @GetTipoColor(produto.Tipo);">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                                                </div>
                                                <div class="name-info">
                                                    <span class="name-primary">@produto.Descricao</span>
                                                    @if (!string.IsNullOrEmpty(produto.Ean))
                                                    {
                                                        <span class="name-secondary">EAN: @produto.Ean</span>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="type-badge" style="background: @GetTipoColor(produto.Tipo)20; color: @GetTipoColor(produto.Tipo);">
                                                @GetTipoLabel(produto.Tipo)
                                            </span>
                                        </td>
                                        <td class="cell-marca">@(produto.Marca?.Nome ?? "-")</td>
                                        <td class="cell-price">@produto.CustoMedio.ToString("C2")</td>
                                        <td class="cell-price cell-venda">@produto.PrecoVenda.ToString("C2")</td>
                                        <td>
                                            <span class="status-badge @GetSituacaoCssClass(produto.Situacao)">
                                                @GetSituacaoLabel(produto.Situacao)
                                            </span>
                                        </td>
                                        <td>
                                            <div class="action-buttons">
                                                <button class="btn-action btn-edit" @onclick="() => EditarProduto(produto)" title="Editar">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                                </button>
                                                <button class="btn-action btn-delete" @onclick="() => ConfirmarDelete(produto)" title="Excluir">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                @if (!filteredProdutos.Any())
                                {
                                    <tr>
                                        <td colspan="8" class="empty-row">
                                            <div class="empty-table">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
                                                <p>Nenhum produto encontrado</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (showDeleteModal)
    {
        <div class="modal-overlay" @onclick="CancelarDelete">
            <div class="modal-content" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h3>Confirmar Exclusao</h3>
                    <button class="modal-close" @onclick="CancelarDelete">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </div>
                <div class="modal-body">
                    <p>Tem certeza que deseja excluir o produto "<strong>@produtoParaExcluir?.Descricao</strong>"?</p>
                    <p class="warning-text">Esta acao e permanente e nao pode ser desfeita.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelarDelete">Cancelar</button>
                    <button class="btn btn-danger" @onclick="ExcluirProduto">Excluir</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Produto> produtos = new();
    private List<Produto> filteredProdutos = new();
    private bool isLoading = true;
    private string searchTerm = string.Empty;
    private bool showDeleteModal = false;
    private Produto? produtoParaExcluir;

    protected override async Task OnInitializedAsync()
    {
        await CarregarProdutos();
    }

    private async Task CarregarProdutos()
    {
        isLoading = true;
        try
        {
            produtos = await ProdutosService.GetAllAsync();
            filteredProdutos = produtos;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar produtos: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnSearch()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredProdutos = produtos;
        }
        else
        {
            filteredProdutos = produtos.Where(p =>
                p.Descricao.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                (p.Sku?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (p.Ean?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (p.Marca?.Nome.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (p.Categoria?.Nome.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
            ).ToList();
        }
    }

    private async Task NovoProduto()
    {
        await WinBoxService.OpenWindow("produto-edit-nova", "Novo Produto", "/produtos/novo", 800, 700);
    }

    private async Task EditarProduto(Produto produto)
    {
        await WinBoxService.OpenWindow($"produto-edit-{produto.Id}", "Editar Produto", $"/produtos/{produto.Id}", 800, 700);
    }

    private void ConfirmarDelete(Produto produto)
    {
        produtoParaExcluir = produto;
        showDeleteModal = true;
    }

    private void CancelarDelete()
    {
        showDeleteModal = false;
        produtoParaExcluir = null;
    }

    private async Task ExcluirProduto()
    {
        if (produtoParaExcluir != null)
        {
            try
            {
                await ProdutosService.DeleteAsync(produtoParaExcluir.Id);
                await CarregarProdutos();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Erro ao excluir produto: {ex.Message}");
            }
        }
        showDeleteModal = false;
        produtoParaExcluir = null;
    }

    private string GetTipoColor(TipoProduto tipo) => tipo switch
    {
        TipoProduto.MERCADORIA => "#3b82f6",
        TipoProduto.MATERIA_PRIMA => "#f59e0b",
        TipoProduto.PRODUTO_ACABADO => "#10b981",
        TipoProduto.EMBALAGEM => "#8b5cf6",
        TipoProduto.USO_CONSUMO => "#06b6d4",
        _ => "#6b7280"
    };

    private string GetTipoLabel(TipoProduto tipo) => tipo switch
    {
        TipoProduto.MERCADORIA => "Mercadoria",
        TipoProduto.MATERIA_PRIMA => "Mat. Prima",
        TipoProduto.PRODUTO_ACABADO => "Prod. Acabado",
        TipoProduto.EMBALAGEM => "Embalagem",
        TipoProduto.USO_CONSUMO => "Uso Consumo",
        _ => "-"
    };

    private string GetSituacaoColor(SituacaoProduto situacao) => situacao switch
    {
        SituacaoProduto.ATIVO => "#10b981",
        SituacaoProduto.INATIVO => "#6b7280",
        SituacaoProduto.RASCUNHO => "#f59e0b",
        SituacaoProduto.AGUARDANDO_FISCAL => "#8b5cf6",
        SituacaoProduto.AGUARDANDO_PCP => "#06b6d4",
        SituacaoProduto.PENDENTE_APROVACAO => "#ec4899",
        _ => "#6b7280"
    };

    private string GetSituacaoCssClass(SituacaoProduto situacao) => situacao switch
    {
        SituacaoProduto.ATIVO => "status-active",
        SituacaoProduto.INATIVO => "status-inactive",
        SituacaoProduto.RASCUNHO => "status-warning",
        SituacaoProduto.AGUARDANDO_FISCAL => "status-info",
        SituacaoProduto.AGUARDANDO_PCP => "status-info",
        SituacaoProduto.PENDENTE_APROVACAO => "status-danger",
        _ => "status-inactive"
    };

    private string GetSituacaoLabel(SituacaoProduto situacao) => situacao switch
    {
        SituacaoProduto.ATIVO => "Ativo",
        SituacaoProduto.INATIVO => "Inativo",
        SituacaoProduto.RASCUNHO => "Rascunho",
        SituacaoProduto.AGUARDANDO_FISCAL => "Aguard. Fiscal",
        SituacaoProduto.AGUARDANDO_PCP => "Aguard. PCP",
        SituacaoProduto.PENDENTE_APROVACAO => "Pendente",
        _ => "-"
    };
}