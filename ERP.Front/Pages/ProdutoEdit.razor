@page "/produtos/{Id:guid?}"
@page "/produtos/novo"
@using ERP.Front.Models
@inject ProdutosService ProdutosService
@inject CategoriasService CategoriasService
@inject MarcasService MarcasService
@inject WinBoxService WinBoxService
@inject NavigationManager Navigation

<PageTitle>@(IsEditMode ? "Editar Produto" : "Novo Produto") - ERP</PageTitle>

<div class="form-page">
    <div class="page-header">
        <button class="btn btn-back" @onclick="Voltar" hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Voltar
        </button>
        <div class="header-content">
            <h1 class="page-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    @if (IsEditMode)
                    {
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    }
                    else
                    {
                        <line x1="12" y1="5" x2="12" y2="19"/>
                        <line x1="5" y1="12" x2="19" y2="12"/>
                    }
                </svg>
                @(IsEditMode ? "Editar Produto" : "Novo Produto")
            </h1>
            <p class="page-subtitle">@(IsEditMode ? "Atualize as informacoes do produto" : "Preencha os dados para criar um novo produto")</p>
        </div>
    </div>

    <div class="form-container form-container-xl">
        <div class="form-card">
            <div class="tabs">
                <button class="tab-btn" @onclick="() => { Tab = 'b'; }">Basico</button>
                <button class="tab-btn" @onclick="() => { Tab = 'p'; }">Precificacao</button>
                <button class="tab-btn" @onclick="() => { Tab = 'f'; }">Fiscal</button>
                <button class="tab-btn" @onclick="() => { Tab = 'e'; }">Estoque</button>
            </div>

            <EditForm Model="produtoForm" OnValidSubmit="Salvar">
                <DataAnnotationsValidator />
                <ValidationSummary />

                @if (Tab == 'b')
                {
                    <div class="tab-content">
                        <div class="form-section">
                            <h3 class="form-section-title">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                                Identificação
                            </h3>
                            <div class="form-grid">
                                <div class="form-group">
                                    <label for="sku">SKU</label>
                                    <div class="input-wrapper">
                                        <InputText id="sku" @bind-Value="produtoForm.Sku" placeholder="COD-001" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="ean">EAN</label>
                                    <div class="input-wrapper">
                                        <InputText id="ean" @bind-Value="produtoForm.Ean" placeholder="7891234567890" />
                                    </div>
                                </div>
                                <div class="form-group full-width">
                                    <label for="descricao">Descrição *</label>
                                    <div class="input-wrapper">
                                        <InputText id="descricao" @bind-Value="produtoForm.Descricao" placeholder="Nome do produto" />
                                    </div>
                                    <ValidationMessage For="@(() => produtoForm.Descricao)" />
                                </div>
                                <div class="form-group">
                                    <label for="tipo">Tipo</label>
                                    <div class="input-wrapper select-wrapper">
                                        <InputSelect id="tipo" @bind-Value="produtoForm.Tipo">
                                            <option value="@TipoProduto.MERCADORIA">Mercadoria</option>
                                            <option value="@TipoProduto.MATERIA_PRIMA">Materia Prima</option>
                                            <option value="@TipoProduto.PRODUTO_ACABADO">Produto Acabado</option>
                                            <option value="@TipoProduto.EMBALAGEM">Embalagem</option>
                                            <option value="@TipoProduto.USO_CONSUMO">Uso e Consumo</option>
                                        </InputSelect>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="unidade">Unidade</label>
                                    <div class="input-wrapper select-wrapper">
                                        <InputSelect id="unidade" @bind-Value="produtoForm.UnidadeMedida">
                                            <option value="@UnidadeMedida.UN">Unidade</option>
                                            <option value="@UnidadeMedida.KG">Kg</option>
                                            <option value="@UnidadeMedida.PC">Peca</option>
                                            <option value="@UnidadeMedida.CX">Caixa</option>
                                            <option value="@UnidadeMedida.MT">Metro</option>
                                        </InputSelect>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="situacao">Situação</label>
                                    <div class="input-wrapper select-wrapper">
                                        <InputSelect id="situacao" @bind-Value="produtoForm.Situacao">
                                            <option value="@SituacaoProduto.RASCUNHO">Rascunho</option>
                                            <option value="@SituacaoProduto.ATIVO">Ativo</option>
                                            <option value="@SituacaoProduto.INATIVO">Inativo</option>
                                            <option value="@SituacaoProduto.AGUARDANDO_FISCAL">Aguardando Fiscal</option>
                                            <option value="@SituacaoProduto.AGUARDANDO_PCP">Aguardando PCP</option>
                                            <option value="@SituacaoProduto.PENDENTE_APROVACAO">Pendente Aprovacao</option>
                                        </InputSelect>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="form-section">
                            <h3 class="form-section-title">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                                Classificação
                            </h3>
                            <div class="form-grid">
                                <div class="form-group">
                                    <label for="categoria">Categoria</label>
                                    <div class="input-wrapper select-wrapper">
                                        <InputSelect id="categoria" @bind-Value="produtoForm.CategoriaId">
                                            <option value="">Selecione</option>
                                            @foreach (var categoria in categorias)
                                            {
                                                <option value="@categoria.Id">@categoria.Nome</option>
                                            }
                                        </InputSelect>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="marca">Marca</label>
                                    <div class="input-wrapper select-wrapper">
                                        <InputSelect id="marca" @bind-Value="produtoForm.MarcaId">
                                            <option value="">Selecione</option>
                                            @foreach (var marca in marcas)
                                            {
                                                <option value="@marca.Id">@marca.Nome</option>
                                            }
                                        </InputSelect>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="form-section">
                            <h3 class="form-section-title">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="17" y1="10" x2="3" y2="10"/><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="14" x2="3" y2="14"/><line x1="17" y1="18" x2="3" y2="18"/></svg>
                                Descricoes Complementares
                            </h3>
                            <div class="form-group full-width">
                                <div class="input-wrapper textarea-wrapper">
                                    <InputTextArea id="descNFe" @bind-Value="produtoForm.DescricaoNFe" placeholder="Descricao para NFe..." rows="2" />
                                </div>
                            </div>
                            <div class="form-group full-width">
                                <div class="input-wrapper textarea-wrapper">
                                    <InputTextArea id="descComp" @bind-Value="produtoForm.DescricaoComplementar" placeholder="Descricao complementar..." rows="2" />
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else if (Tab == 'p')
                {
                    <div class="tab-content">
                        <div class="form-section">
                            <h3 class="form-section-title">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                                precos
                            </h3>
                            <div class="form-grid form-grid-4">
                                <div class="form-group">
                                    <label for="custo">Custo Medio</label>
                                    <div class="input-wrapper">
                                        <span class="input-prefix">R$</span>
                                        <InputNumber id="custo" @bind-Value="produtoForm.CustoMedio" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="ultima">Ultima Compra</label>
                                    <div class="input-wrapper">
                                        <span class="input-prefix">R$</span>
                                        <InputNumber id="ultima" @bind-Value="produtoForm.UltimaCompra" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="markup">Markup (%)</label>
                                    <div class="input-wrapper">
                                        <InputNumber id="markup" @bind-Value="produtoForm.Markup" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="venda">Preco Venda *</label>
                                    <div class="input-wrapper">
                                        <span class="input-prefix">R$</span>
                                        <InputNumber id="venda" @bind-Value="produtoForm.PrecoVenda" />
                                    </div>
                                    <ValidationMessage For="@(() => produtoForm.PrecoVenda)" />
                                </div>
                                <div class="form-group">
                                    <label for="minimo">Preco Minimo</label>
                                    <div class="input-wrapper">
                                        <span class="input-prefix">R$</span>
                                        <InputNumber id="minimo" @bind-Value="produtoForm.PrecoMinimo" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else if (Tab == 'f')
                {
                    <div class="tab-content">
                        <div class="form-section">
                            <h3 class="form-section-title">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                Informacoes Fiscais
                            </h3>
                            <div class="form-grid form-grid-4">
                                <div class="form-group">
                                    <label for="ncm">NCM</label>
                                    <div class="input-wrapper">
                                        <InputText id="ncm" @bind-Value="produtoForm.Ncm" placeholder="0000.00.00" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="cest">CEST</label>
                                    <div class="input-wrapper">
                                        <InputText id="cest" @bind-Value="produtoForm.CEST" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="origem">Origem</label>
                                    <div class="input-wrapper">
                                        <InputNumber id="origem" @bind-Value="produtoForm.Origem" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="cfop">CFOP</label>
                                    <div class="input-wrapper">
                                        <InputText id="cfop" @bind-Value="produtoForm.Cfop" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="form-section">
                            <h3 class="form-section-title">ICMS</h3>
                            <div class="form-grid form-grid-4">
                                <div class="form-group">
                                    <label for="cstIcms">CST ICMS</label>
                                    <div class="input-wrapper">
                                        <InputText id="cstIcms" @bind-Value="produtoForm.CstIcms" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="aliqIcms">Aliq. ICMS (%)</label>
                                    <div class="input-wrapper">
                                        <InputNumber id="aliqIcms" @bind-Value="produtoForm.AliqIcms" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="mvaSt">MVA ST (%)</label>
                                    <div class="input-wrapper">
                                        <InputNumber id="mvaSt" @bind-Value="produtoForm.MvaSt" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="form-section">
                            <h3 class="form-section-title">PIS/COFINS</h3>
                            <div class="form-grid form-grid-4">
                                <div class="form-group">
                                    <label for="cstPis">CST PIS</label>
                                    <div class="input-wrapper">
                                        <InputText id="cstPis" @bind-Value="produtoForm.CstPis" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="aliqPis">Aliq. PIS (%)</label>
                                    <div class="input-wrapper">
                                        <InputNumber id="aliqPis" @bind-Value="produtoForm.AliqPis" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="aliqCofins">Aliq. COFINS (%)</label>
                                    <div class="input-wrapper">
                                        <InputNumber id="aliqCofins" @bind-Value="produtoForm.AliqCofins" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else if (Tab == 'e')
                {
                    <div class="tab-content">
                        <div class="form-section">
                            <h3 class="form-section-title">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                                Dimenses e Peso
                            </h3>
                            <div class="form-grid form-grid-4">
                                <div class="form-group">
                                    <label for="pesoLiq">Peso Liquido (kg)</label>
                                    <div class="input-wrapper">
                                        <InputNumber id="pesoLiq" @bind-Value="produtoForm.PesoLiquido" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="pesoBruto">Peso Bruto (kg)</label>
                                    <div class="input-wrapper">
                                        <InputNumber id="pesoBruto" @bind-Value="produtoForm.PesoBruto" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="altura">Altura (cm)</label>
                                    <div class="input-wrapper">
                                        <InputNumber id="altura" @bind-Value="produtoForm.Altura" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="largura">Largura (cm)</label>
                                    <div class="input-wrapper">
                                        <InputNumber id="largura" @bind-Value="produtoForm.Largura" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="profundidade">Profundidade (cm)</label>
                                    <div class="input-wrapper">
                                        <InputNumber id="profundidade" @bind-Value="produtoForm.Profundidade" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="form-section">
                            <h3 class="form-section-title">Controle de Estoque</h3>
                            <div class="form-grid form-grid-4">
                                <div class="form-group">
                                    <label for="estoqueMin">Estoque Minimo</label>
                                    <div class="input-wrapper">
                                        <InputNumber id="estoqueMin" @bind-Value="produtoForm.EstoqueMinimo" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="estoqueAtual">Estoque Atual</label>
                                    <div class="input-wrapper">
                                        <InputNumber id="estoqueAtual" @bind-Value="produtoForm.EstoqueAtual" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="pontoRepo">Ponto de Reposicao</label>
                                    <div class="input-wrapper">
                                        <InputNumber id="pontoRepo" @bind-Value="produtoForm.PontoReposicao" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="leadTime">Lead Time (dias)</label>
                                    <div class="input-wrapper">
                                        <InputNumber id="leadTime" @bind-Value="produtoForm.LeadTime" />
                                    </div>
                                </div>
                            </div>
                            <div class="form-grid form-grid-3">
                                <div class="form-group checkbox-group">
                                    <label class="checkbox-label">
                                        <InputCheckbox @bind-Value="produtoForm.ControlaEstoque" />
                                        <span>Controla Estoque</span>
                                    </label>
                                </div>
                                <div class="form-group checkbox-group">
                                    <label class="checkbox-label">
                                        <InputCheckbox @bind-Value="produtoForm.ControlaLote" />
                                        <span>Controla Lote</span>
                                    </label>
                                </div>
                                <div class="form-group checkbox-group">
                                    <label class="checkbox-label">
                                        <InputCheckbox @bind-Value="produtoForm.ControlaValidade" />
                                        <span>Controla Validade</span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="form-section">
                            <div class="form-group">
                                <label for="localizacao">Localizacao no Armazem</label>
                                <div class="input-wrapper">
                                    <InputText id="localizacao" @bind-Value="produtoForm.Localizacao" placeholder="Ex: Corredor A, Pratileira 3" />
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" @onclick="Voltar" hidden="true">Cancelar</button>
                    <button type="submit" class="btn btn-primary" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner"></span>
                            @(IsEditMode ? "Salvando..." : "Criando...")
                            isSaving = false;
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            @(IsEditMode ? "Salvar Alteracoes" : "Criar Produto")
                        }
                    </button>
                </div>
            </EditForm>
        </div>

        <div class="preview-card">
            <h3 class="preview-title">Resumo do Produto</h3>
            <div class="preview-content">
                <div class="preview-item">
                    <span class="preview-label">SKU</span>
                    <span class="preview-value">@(!string.IsNullOrEmpty(produtoForm.Sku) ? produtoForm.Sku : "-")</span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Descricao</span>
                    <span class="preview-value">@(!string.IsNullOrEmpty(produtoForm.Descricao) ? produtoForm.Descricao : "-")</span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Tipo</span>
                    <span class="preview-badge" style="background: @GetTipoColor(produtoForm.Tipo)20; color: @GetTipoColor(produtoForm.Tipo);">
                        @GetTipoLabel(produtoForm.Tipo)
                    </span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Unidade</span>
                    <span class="preview-value">@produtoForm.UnidadeMedida</span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Preco Venda</span>
                    <span class="preview-value preview-price">@produtoForm.PrecoVenda.ToString("C2")</span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Custo</span>
                    <span class="preview-value">@produtoForm.CustoMedio.ToString("C2")</span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">NCM</span>
                    <span class="preview-value">@(!string.IsNullOrEmpty(produtoForm.Ncm) ? produtoForm.Ncm : "-")</span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Status</span>
                    <span class="preview-badge @GetSituacaoCssClass(produtoForm.Situacao)">
                        @GetSituacaoLabel(produtoForm.Situacao)
                    </span>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-error">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            @errorMessage
        </div>
    }

    @if (showSuccessToast)
    {
        <div class="alert alert-success">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            Produto criado com sucesso! Modo de edição ativado.
        </div>
    }

    @if (showResultModal)
    {
        <div class="modal-overlay" @onclick="FecharResultModal">
            <div class="modal-content" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h3>
                        @if (isSuccess)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        }
                        @(isSuccess ? "Sucesso" : "Erro")
                    </h3>
                </div>
                <div class="modal-body">
                    <p>@resultMessage</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="FecharResultModal">OK</button>
                </div>
            </div>
        </div>
    }
</div>

@code {

    [Parameter]
    public Guid? Id { get; set; }

    private ProdutoForm produtoForm = new();
    private bool isSaving = false;
    private string errorMessage = string.Empty;
    private string activeTab = "b";

    private char Tab = 'b';

    private List<Categoria> categorias = new();
    private List<Marca> marcas = new();
    private bool showSuccessToast = false;
    private bool modoEdicaoForcado = false;
    private bool showResultModal = false;
    private bool isSuccess = false;
    private string resultMessage = string.Empty;

    private bool IsEditMode => modoEdicaoForcado || (Id.HasValue && Id != Guid.Empty);

    protected override async Task OnInitializedAsync()
    {
        var taskCategorias = CategoriasService.GetAllAsync();
        var taskMarcas = MarcasService.GetAllAsync();

        await Task.WhenAll(taskCategorias, taskMarcas);

        categorias = await taskCategorias;
        marcas = await taskMarcas;

        if (IsEditMode && Id.HasValue)
        {
            await CarregarProduto();
        }
    }

    private async Task CarregarProduto()
    {
        try
        {
            var produto = await ProdutosService.GetByIdAsync(Id!.Value);
            if (produto != null)
            {
                produtoForm = new ProdutoForm
                {
                    Sku = produto.Sku,
                    Ean = produto.Ean,
                    Tipo = produto.Tipo,
                    UnidadeMedida = produto.UnidadeMedida,
                    Descricao = produto.Descricao,
                    DescricaoNFe = produto.DescricaoNFe,
                    DescricaoComplementar = produto.DescricaoComplementar,
                    CategoriaId = produto.CategoriaId,
                    MarcaId = produto.MarcaId,
                    Situacao = produto.Situacao,
                    CustoMedio = produto.CustoMedio,
                    UltimaCompra = produto.UltimaCompra,
                    Markup = produto.Markup,
                    PrecoVenda = produto.PrecoVenda,
                    PrecoMinimo = produto.PrecoMinimo,
                    Ncm = produto.Ncm,
                    CEST = produto.CEST,
                    Origem = produto.Origem,
                    Cfop = produto.Cfop,
                    CstIcms = produto.CstIcms,
                    AliqIcms = produto.AliqIcms,
                    MvaSt = produto.MvaSt,
                    CstPis = produto.CstPis,
                    AliqPis = produto.AliqPis,
                    AliqCofins = produto.AliqCofins,
                    PesoLiquido = produto.PesoLiquido,
                    PesoBruto = produto.PesoBruto,
                    Altura = produto.Altura,
                    Largura = produto.Largura,
                    Profundidade = produto.Profundidade,
                    EstoqueMinimo = produto.EstoqueMinimo,
                    EstoqueAtual = produto.EstoqueAtual,
                    PontoReposicao = produto.PontoReposicao,
                    LeadTime = produto.LeadTime,
                    ControlaLote = produto.ControlaLote,
                    ControlaValidade = produto.ControlaValidade,
                    ControlaEstoque = produto.ControlaEstoque,
                    Localizacao = produto.Localizacao
                };
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar produto: {ex.Message}";
        }
    }

    private async Task Salvar()
    {
        isSaving = true;
        errorMessage = string.Empty;

        try
        {
            Produto? result;
            if (IsEditMode && Id.HasValue)
            {
                result = await ProdutosService.UpdateAsync(Id!.Value, produtoForm);
            }
            else
            {
                result = await ProdutosService.CreateAsync(produtoForm);
            }

            if (result != null)
            {
                isSuccess = true;
                resultMessage = IsEditMode ? "Produto atualizado com sucesso!" : "Produto criado com sucesso!";
                showResultModal = true;
            }
            else
            {
                isSuccess = false;
                resultMessage = "Erro ao salvar produto. Tente novamente.";
                showResultModal = true;
            }
        }
        catch (Exception ex)
        {
            isSuccess = false;
            resultMessage = $"Erro ao salvar: {ex.Message}";
            showResultModal = true;
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Voltar()
    {
        Navigation.NavigateTo("/produtos");
    }

    // private void SetTab(string tab)
    // {
    //     activeTab = tab;
    // }

    private string GetTabClass(string tab)
    {
        return activeTab == tab ? "active" : "";
    }

    private string GetTipoColor(TipoProduto tipo) => tipo switch
    {
        TipoProduto.MERCADORIA => "#3b82f6",
        TipoProduto.MATERIA_PRIMA => "#f59e0b",
        TipoProduto.PRODUTO_ACABADO => "#10b981",
        TipoProduto.EMBALAGEM => "#8b5cf6",
        TipoProduto.USO_CONSUMO => "#06b6d4",
        _ => "#6b7280"
    };

    private string GetTipoLabel(TipoProduto tipo) => tipo switch
    {
        TipoProduto.MERCADORIA => "Mercadoria",
        TipoProduto.MATERIA_PRIMA => "Mat. Prima",
        TipoProduto.PRODUTO_ACABADO => "Prod. Acabado",
        TipoProduto.EMBALAGEM => "Embalagem",
        TipoProduto.USO_CONSUMO => "Uso Consumo",
        _ => "-"
    };

    private string GetSituacaoCssClass(SituacaoProduto situacao) => situacao switch
    {
        SituacaoProduto.ATIVO => "badge-active",
        SituacaoProduto.INATIVO => "badge-inactive",
        SituacaoProduto.RASCUNHO => "badge-warning",
        _ => "badge-inactive"
    };

    private string GetSituacaoLabel(SituacaoProduto situacao) => situacao switch
    {
        SituacaoProduto.ATIVO => "Ativo",
        SituacaoProduto.INATIVO => "Inativo",
        SituacaoProduto.RASCUNHO => "Rascunho",
        SituacaoProduto.AGUARDANDO_FISCAL => "Aguard. Fiscal",
        SituacaoProduto.AGUARDANDO_PCP => "Aguard. PCP",
        SituacaoProduto.PENDENTE_APROVACAO => "Pendente",
        _ => "-"
    };

    private void FecharResultModal()
    {
        showResultModal = false;
        if (isSuccess)
        {
            FecharJanela();
        }
        isSuccess = false;
        resultMessage = string.Empty;
    }

    private void FecharJanela()
    {
        var windowId = WinBoxService.Windows.Keys
            .FirstOrDefault(k => k.Contains("produto-edit-"));
        _ = WinBoxService.CloseWindow(windowId ?? "produto-edit-nova");
    }

    private void LimparFormulario()
    {
        produtoForm = new ProdutoForm();
        Id = null;
        modoEdicaoForcado = false;
        showResultModal = false;
        isSuccess = false;
        resultMessage = string.Empty;
    }
}