@page "/categorias/{Id:guid?}"
@page "/categorias/nova"
@inject CategoriasService CategoriasService
@inject WinBoxService WinBoxService
@inject NavigationManager Navigation

<PageTitle>@(IsEditMode ? "Editar Categoria" : "Nova Categoria") - ERP</PageTitle>

<div class="form-page">
    <div class="page-header">
        <button class="btn btn-back" @onclick="Voltar" hidden ="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Voltar
        </button>
        <div class="header-content">
            <h1 class="page-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    @if (IsEditMode)
                    {
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    }
                    else
                    {
                        <line x1="12" y1="5" x2="12" y2="19"/>
                        <line x1="5" y1="12" x2="19" y2="12"/>
                    }
                </svg>
                @(IsEditMode ? "Editar Categoria" : "Nova Categoria")
            </h1>
            <p class="page-subtitle">@(IsEditMode ? "Atualize as informacoes da categoria" : "Preencha os dados para criar uma nova categoria")</p>
        </div>
    </div>

    <div class="form-container">
        <div class="form-card">
            <EditForm Model="categoriaForm" OnValidSubmit="Salvar">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-grid">
                    <div class="form-group">
                        <label for="nome">Nome da Categoria *</label>
                        <div class="input-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                            <InputText id="nome" @bind-Value="categoriaForm.Nome" placeholder="Ex: Eletronicos" />
                        </div>
                        <ValidationMessage For="@(() => categoriaForm.Nome)" />
                    </div>

                    <div class="form-group">
                        <label for="tipo">Tipo de Categoria *</label>
                        <div class="input-wrapper select-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
                            <InputSelect id="tipo" @bind-Value="categoriaForm.Tipo">
                                <option value="@TipoCategoria.PRODUTO">Produto</option>
                                <option value="@TipoCategoria.SERVICO">Servico</option>
                                <option value="@TipoCategoria.MATERIA_PRIMA">Materia Prima</option>
                            </InputSelect>
                        </div>
                    </div>

                    <div class="form-group full-width">
                        <label for="descricao">Descricao</label>
                        <div class="input-wrapper textarea-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="17" y1="10" x2="3" y2="10"/><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="14" x2="3" y2="14"/><line x1="17" y1="18" x2="3" y2="18"/></svg>
                            <InputTextArea id="descricao" @bind-Value="categoriaForm.Descricao" placeholder="Descricao opcional da categoria..." rows="4" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="toggle-label">
                            <span class="toggle-text">Categoria Ativa</span>
                            <div class="toggle-wrapper">
                                <InputCheckbox id="ativa" @bind-Value="categoriaForm.Ativa" />
                                <span class="toggle-switch"></span>
                            </div>
                        </label>
                        <p class="form-hint">Categorias ativas aparecem nas listagens publicas</p>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" @onclick="Voltar" hidden="true">Cancelar</button>
                    <button type="submit" class="btn btn-primary" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner"></span>
                            @(IsEditMode ? "Salvando..." : "Criando...")
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            @(IsEditMode ? "Salvar Alteracoes" : "Criar Categoria")
                        }
                    </button>
                </div>
            </EditForm>
        </div>

        <div class="preview-card">
            <h3 class="preview-title">Pre-visualizacao</h3>
            <div class="preview-content">
                <div class="preview-item">
                    <span class="preview-label">Nome</span>
                    <span class="preview-value">@(!string.IsNullOrEmpty(categoriaForm.Nome) ? categoriaForm.Nome : "Nome da categoria")</span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Tipo</span>
                    <span class="preview-badge" style="background: @GetTipoColor(categoriaForm.Tipo)20; color: @GetTipoColor(categoriaForm.Tipo);">
                        @GetTipoLabel(categoriaForm.Tipo)
                    </span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Descricao</span>
                    <span class="preview-value">@(!string.IsNullOrEmpty(categoriaForm.Descricao) ? categoriaForm.Descricao : "Sem descricao")</span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Status</span>
                    <span class="preview-badge @(categoriaForm.Ativa ? "badge-active" : "badge-inactive")">
                        @(categoriaForm.Ativa ? "Ativa" : "Inativa")
                    </span>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-error">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            @errorMessage
        </div>
    }

    @if (showResultModal)
    {
        <div class="modal-overlay" @onclick="FecharResultModal">
            <div class="modal-content" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h3>
                        @if (isSuccess)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        }
                        @(isSuccess ? "Sucesso" : "Erro")
                    </h3>
                </div>
                <div class="modal-body">
                    <p>@resultMessage</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="FecharResultModal">OK</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid? Id { get; set; }

    private CategoriaForm categoriaForm = new();
    private bool isSaving = false;
    private string errorMessage = string.Empty;
    private bool showResultModal = false;
    private bool isSuccess = false;
    private string resultMessage = string.Empty;

    private bool IsEditMode => Id.HasValue && Id != Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (IsEditMode && Id.HasValue)
        {
            await CarregarCategoria();
        }
    }

    private async Task CarregarCategoria()
    {
        try
        {
            var categoria = await CategoriasService.GetByIdAsync(Id!.Value);
            if (categoria != null)
            {
                categoriaForm = new CategoriaForm
                {
                    Nome = categoria.Nome,
                    Descricao = categoria.Descricao,
                    Tipo = categoria.Tipo,
                    Ativa = categoria.Ativa
                };
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar categoria: {ex.Message}";
        }
    }

    private async Task Salvar()
    {
        isSaving = true;
        errorMessage = string.Empty;

        try
        {
            Categoria? result;
            if (IsEditMode && Id.HasValue)
            {
                result = await CategoriasService.UpdateAsync(Id!.Value, categoriaForm);
            }
            else
            {
                result = await CategoriasService.CreateAsync(categoriaForm);
            }

            if (result != null)
            {
                isSuccess = true;
                resultMessage = IsEditMode ? "Categoria atualizada com sucesso!" : "Categoria criada com sucesso!";
                showResultModal = true;
            }
            else
            {
                isSuccess = false;
                resultMessage = "Erro ao salvar categoria. Tente novamente.";
                showResultModal = true;
            }
        }
        catch (Exception ex)
        {
            isSuccess = false;
            resultMessage = $"Erro ao salvar: {ex.Message}";
            showResultModal = true;
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Voltar()
    {
        Navigation.NavigateTo("/categorias");
    }

    private string GetTipoColor(TipoCategoria tipo) => tipo switch
    {
        TipoCategoria.PRODUTO => "#3b82f6",
        TipoCategoria.SERVICO => "#10b981",
        TipoCategoria.MATERIA_PRIMA => "#f59e0b",
        _ => "#6b7280"
    };

    private string GetTipoLabel(TipoCategoria tipo) => tipo switch
    {
        TipoCategoria.PRODUTO => "Produto",
        TipoCategoria.SERVICO => "Servico",
        TipoCategoria.MATERIA_PRIMA => "Materia Prima",
        _ => "Desconhecido"
    };

    private void FecharResultModal()
    {
        showResultModal = false;
        if (isSuccess)
        {
            FecharJanela();
        }
        isSuccess = false;
        resultMessage = string.Empty;
    }

    private void FecharJanela()
    {
        var windowId = WinBoxService.Windows.Keys
            .FirstOrDefault(k => k.Contains("categoria-edit-"));
        _ = WinBoxService.CloseWindow(windowId ?? "categoria-edit-nova");
    }

    private void LimparFormulario()
    {
        categoriaForm = new CategoriaForm();
        Id = null;
        showResultModal = false;
        isSuccess = false;
        resultMessage = string.Empty;
    }
}