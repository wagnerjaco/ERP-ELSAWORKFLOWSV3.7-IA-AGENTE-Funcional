@page "/fornecedores/{Id:guid?}"
@page "/fornecedores/novo"
@inject FornecedoresService FornecedoresService
@inject WinBoxService WinBoxService
@inject NavigationManager Navigation

<PageTitle>@(IsEditMode ? "Editar Fornecedor" : "Novo Fornecedor") - ERP</PageTitle>

<div class="form-page">
    <div class="page-header">
        <button class="btn btn-back" @onclick="Voltar" hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Voltar
        </button>
        <div class="header-content">
            <h1 class="page-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    @if (IsEditMode)
                    {
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    }
                    else
                    {
                        <line x1="12" y1="5" x2="12" y2="19"/>
                        <line x1="5" y1="12" x2="19" y2="12"/>
                    }
                </svg>
                @(IsEditMode ? "Editar Fornecedor" : "Novo Fornecedor")
            </h1>
            <p class="page-subtitle">@(IsEditMode ? "Atualize as informacoes do fornecedor" : "Preencha os dados para adicionar um novo fornecedor")</p>
        </div>
    </div>

    <div class="form-container form-container-lg">
        <div class="form-card">
            <EditForm Model="fornecedorForm" OnValidSubmit="Salvar">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-section">
                    <h3 class="form-section-title">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        Dados Pessoais
                    </h3>
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="tipoPessoa">Tipo *</label>
                            <div class="input-wrapper select-wrapper">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
                                <InputSelect id="tipoPessoa" @bind-Value="fornecedorForm.TipoPessoa">
                                    <option value="@TipoPessoa.JURIDICA">Pessoa Juridica</option>
                                    <option value="@TipoPessoa.FISICA">Pessoa Fisica</option>
                                </InputSelect>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="nome">@(fornecedorForm.TipoPessoa == TipoPessoa.JURIDICA ? "Razao Social" : "Nome") *</label>
                            <div class="input-wrapper">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                <InputText id="nome" @bind-Value="fornecedorForm.Nome" placeholder="@(fornecedorForm.TipoPessoa == TipoPessoa.JURIDICA ? "Ex: Empresa Ltda" : "Ex: Joao Silva")" />
                            </div>
                            <ValidationMessage For="@(() => fornecedorForm.Nome)" />
                        </div>
                        <div class="form-group">
                            <label for="nomeFantasia">Nome Fantasia</label>
                            <div class="input-wrapper">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                <InputText id="nomeFantasia" @bind-Value="fornecedorForm.NomeFantasia" placeholder="Nome comercial" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="cpfCnpj">@(fornecedorForm.TipoPessoa == TipoPessoa.JURIDICA ? "CNPJ" : "CPF")</label>
                            <div class="input-wrapper">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                <InputText id="cpfCnpj" @bind-Value="fornecedorForm.CpfCnpj" placeholder="@(fornecedorForm.TipoPessoa == TipoPessoa.JURIDICA ? "00.000.000/0001-00" : "000.000.000-00")" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="rgIe">@(fornecedorForm.TipoPessoa == TipoPessoa.JURIDICA ? "Inscricao Estadual" : "RG")</label>
                            <div class="input-wrapper">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                <InputText id="rgIe" @bind-Value="fornecedorForm.RgIe" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="situacao">Status</label>
                            <div class="input-wrapper select-wrapper">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                <InputSelect id="situacao" @bind-Value="fornecedorForm.Situacao">
                                    <option value="@SituacaoFornecedor.ATIVO">Ativo</option>
                                    <option value="@SituacaoFornecedor.INATIVO">Inativo</option>
                                    <option value="@SituacaoFornecedor.BLOQUEADO">Bloqueado</option>
                                </InputSelect>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-section">
                    <h3 class="form-section-title">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                        Contato
                    </h3>
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="email">Email</label>
                            <div class="input-wrapper">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                                <InputText id="email" @bind-Value="fornecedorForm.Email" placeholder="email@exemplo.com" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="telefone">Telefone</label>
                            <div class="input-wrapper">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                <InputText id="telefone" @bind-Value="fornecedorForm.Telefone" placeholder="(00) 0000-0000" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="celular">Celular</label>
                            <div class="input-wrapper">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
                                <InputText id="celular" @bind-Value="fornecedorForm.Celular" placeholder="(00) 00000-0000" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-section">
                    <h3 class="form-section-title">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        Endereco
                    </h3>
                    <div class="form-grid">
                        <div class="form-group form-group-sm">
                            <label for="cep">CEP</label>
                            <div class="input-wrapper">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                                <InputText id="cep" @bind-Value="fornecedorForm.Cep" placeholder="00000-000" />
                            </div>
                        </div>
                        <div class="form-group form-group-sm">
                            <label for="endereco">Endereco</label>
                            <div class="input-wrapper">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                <InputText id="endereco" @bind-Value="fornecedorForm.Endereco" placeholder="Rua, Avenida, etc" />
                            </div>
                        </div>
                        <div class="form-group form-group-sm">
                            <label for="numero">Numero</label>
                            <div class="input-wrapper">
                                <InputText id="numero" @bind-Value="fornecedorForm.Numero" placeholder="N" />
                            </div>
                        </div>
                        <div class="form-group form-group-sm">
                            <label for="complemento">Complemento</label>
                            <div class="input-wrapper">
                                <InputText id="complemento" @bind-Value="fornecedorForm.Complemento" placeholder="Ap, Sala, etc" />
                            </div>
                        </div>
                        <div class="form-group form-group-sm">
                            <label for="bairro">Bairro</label>
                            <div class="input-wrapper">
                                <InputText id="bairro" @bind-Value="fornecedorForm.Bairro" />
                            </div>
                        </div>
                        <div class="form-group form-group-sm">
                            <label for="cidade">Cidade</label>
                            <div class="input-wrapper">
                                <InputText id="cidade" @bind-Value="fornecedorForm.Cidade" />
                            </div>
                        </div>
                        <div class="form-group form-group-sm">
                            <label for="uf">UF</label>
                            <div class="input-wrapper select-wrapper">
                                <InputSelect id="uf" @bind-Value="fornecedorForm.Uf">
                                    <option value="">Selecione</option>
                                    <option value="AC">AC</option>
                                    <option value="AL">AL</option>
                                    <option value="AP">AP</option>
                                    <option value="AM">AM</option>
                                    <option value="BA">BA</option>
                                    <option value="CE">CE</option>
                                    <option value="DF">DF</option>
                                    <option value="ES">ES</option>
                                    <option value="GO">GO</option>
                                    <option value="MA">MA</option>
                                    <option value="MT">MT</option>
                                    <option value="MS">MS</option>
                                    <option value="MG">MG</option>
                                    <option value="PA">PA</option>
                                    <option value="PB">PB</option>
                                    <option value="PR">PR</option>
                                    <option value="PE">PE</option>
                                    <option value="PI">PI</option>
                                    <option value="RJ">RJ</option>
                                    <option value="RN">RN</option>
                                    <option value="RS">RS</option>
                                    <option value="RO">RO</option>
                                    <option value="RR">RR</option>
                                    <option value="SC">SC</option>
                                    <option value="SP">SP</option>
                                    <option value="SE">SE</option>
                                    <option value="TO">TO</option>
                                </InputSelect>
                            </div>
                        </div>
                        <div class="form-section">
                            <h3 class="form-section-title">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
                                Observacoes
                            </h3>
                            <div class="form-group full-width">
                                <div class="input-wrapper textarea-wrapper">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="17" y1="10" x2="3" y2="10" /><line x1="21" y1="6" x2="3" y2="6" /><line x1="21" y1="14" x2="3" y2="14" /><line x1="17" y1="18" x2="3" y2="18" /></svg>
                                    <InputTextArea id="observacoes" @bind-Value="fornecedorForm.Observacoes" placeholder="Observacoes adicionais sobre o fornecedor..." rows="3" />
                                </div>
</div>
                            
                        </div>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" @onclick="Voltar" hidden="true">Cancelar</button>
                    <button type="submit" class="btn btn-primary" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner"></span>
                            @(IsEditMode ? "Salvando..." : "Criando...")
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                            @(IsEditMode ? "Salvar Alteracoes" : "Criar Fornecedor")
                        }
                    </button>
                </div>
            </EditForm>
        </div>

        <div class="preview-card">
            <h3 class="preview-title">Resumo</h3>
            <div class="preview-content">
                <div class="preview-item">
                    <span class="preview-label">Nome</span>
                    <span class="preview-value">@(!string.IsNullOrEmpty(fornecedorForm.Nome) ? fornecedorForm.Nome : "-")</span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Tipo</span>
                    <span class="preview-badge" style="background: @GetTipoPessoaColor(fornecedorForm.TipoPessoa)20; color: @GetTipoPessoaColor(fornecedorForm.TipoPessoa);">
                        @GetTipoPessoaLabel(fornecedorForm.TipoPessoa)
                    </span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">CPF/CNPJ</span>
                    <span class="preview-value">@(!string.IsNullOrEmpty(fornecedorForm.CpfCnpj) ? fornecedorForm.CpfCnpj : "-")</span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Email</span>
                    <span class="preview-value">@(!string.IsNullOrEmpty(fornecedorForm.Email) ? fornecedorForm.Email : "-")</span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Telefone</span>
                    <span class="preview-value">@(!string.IsNullOrEmpty(fornecedorForm.Telefone) ? fornecedorForm.Telefone : "-")</span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Cidade/UF</span>
                    <span class="preview-value">@(!string.IsNullOrEmpty(fornecedorForm.Cidade) ? $"{fornecedorForm.Cidade}/{fornecedorForm.Uf}" : "-")</span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Status</span>
                    <span class="preview-badge @GetSituacaoCssClass(fornecedorForm.Situacao)">
                        @GetSituacaoLabel(fornecedorForm.Situacao)
                    </span>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-error">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            @errorMessage
        </div>
    }

    @if (showResultModal)
    {
        <div class="modal-overlay" @onclick="FecharResultModal">
            <div class="modal-content" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h3>
                        @if (isSuccess)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        }
                        @(isSuccess ? "Sucesso" : "Erro")
                    </h3>
                </div>
                <div class="modal-body">
                    <p>@resultMessage</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="FecharResultModal">OK</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid? Id { get; set; }

    private FornecedorForm fornecedorForm = new();
    private bool isSaving = false;
    private string errorMessage = string.Empty;
    private bool showResultModal = false;
    private bool isSuccess = false;
    private string resultMessage = string.Empty;

    private bool IsEditMode => Id.HasValue && Id != Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (IsEditMode && Id.HasValue)
        {
            await CarregarFornecedor();
        }
    }

    private async Task CarregarFornecedor()
    {
        try
        {
            var fornecedor = await FornecedoresService.GetByIdAsync(Id!.Value);
            if (fornecedor != null)
            {
                fornecedorForm = new FornecedorForm
                {
                    Nome = fornecedor.Nome,
                    NomeFantasia = fornecedor.NomeFantasia,
                    CpfCnpj = fornecedor.CpfCnpj,
                    RgIe = fornecedor.RgIe,
                    TipoPessoa = fornecedor.TipoPessoa,
                    Email = fornecedor.Email,
                    Telefone = fornecedor.Telefone,
                    Celular = fornecedor.Celular,
                    Cep = fornecedor.Cep,
                    Endereco = fornecedor.Endereco,
                    Numero = fornecedor.Numero,
                    Complemento = fornecedor.Complemento,
                    Bairro = fornecedor.Bairro,
                    Cidade = fornecedor.Cidade,
                    Uf = fornecedor.Uf,
                    Observacoes = fornecedor.Observacoes,
                    Situacao = fornecedor.Situacao
                };
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar fornecedor: {ex.Message}";
        }
    }

    private async Task Salvar()
    {
        isSaving = true;
        errorMessage = string.Empty;

        try
        {
            Fornecedor? result;
            if (IsEditMode && Id.HasValue)
            {
                result = await FornecedoresService.UpdateAsync(Id!.Value, fornecedorForm);
            }
            else
            {
                result = await FornecedoresService.CreateAsync(fornecedorForm);
            }

            if (result != null)
            {
                isSuccess = true;
                resultMessage = IsEditMode ? "Fornecedor atualizado com sucesso!" : "Fornecedor criado com sucesso!";
                showResultModal = true;
            }
            else
            {
                isSuccess = false;
                resultMessage = "Erro ao salvar fornecedor. Tente novamente.";
                showResultModal = true;
            }
        }
        catch (Exception ex)
        {
            isSuccess = false;
            resultMessage = $"Erro ao salvar: {ex.Message}";
            showResultModal = true;
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Voltar()
    {
        Navigation.NavigateTo("/fornecedores");
    }

    private void FecharResultModal()
    {
        showResultModal = false;
        if (isSuccess)
        {
            FecharJanela();
        }
        isSuccess = false;
        resultMessage = string.Empty;
    }

    private void FecharJanela()
    {
        var windowId = WinBoxService.Windows.Keys
            .FirstOrDefault(k => k.Contains("fornecedor-edit-"));
        _ = WinBoxService.CloseWindow(windowId ?? "fornecedor-edit-nova");
    }

    private void LimparFormulario()
    {
        fornecedorForm = new FornecedorForm();
        showResultModal = false;
        isSuccess = false;
        resultMessage = string.Empty;
    }

    private string GetTipoPessoaColor(TipoPessoa tipo) => tipo switch
    {
        TipoPessoa.FISICA => "#8b5cf6",
        TipoPessoa.JURIDICA => "#06b6d4",
        _ => "#6b7280"
    };

    private string GetTipoPessoaLabel(TipoPessoa tipo) => tipo switch
    {
        TipoPessoa.FISICA => "Pessoa Fisica",
        TipoPessoa.JURIDICA => "Pessoa Juridica",
        _ => "-"
    };

    private string GetSituacaoCssClass(SituacaoFornecedor situacao) => situacao switch
    {
        SituacaoFornecedor.ATIVO => "badge-active",
        SituacaoFornecedor.INATIVO => "badge-warning",
        SituacaoFornecedor.BLOQUEADO => "badge-danger",
        _ => "badge-inactive"
    };

    private string GetSituacaoLabel(SituacaoFornecedor situacao) => situacao switch
    {
        SituacaoFornecedor.ATIVO => "Ativo",
        SituacaoFornecedor.INATIVO => "Inativo",
        SituacaoFornecedor.BLOQUEADO => "Bloqueado",
        _ => "-"
    };
}