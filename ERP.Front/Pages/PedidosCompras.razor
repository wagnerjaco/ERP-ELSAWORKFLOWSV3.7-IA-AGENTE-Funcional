@page "/pedidoscompras"
@using ERP.Front.Models
@inject PedidoComprasService PedidoComprasService
@inject NavigationManager Navigation
@inject WinBoxService WinBoxService

<PageTitle>Pedidos de Compra - ERP</PageTitle>

<div class="pedidoscompra-page window-content">
    <div class="page-header">
        <div class="header-content">
            <h1 class="page-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                Pedidos de Compra
            </h1>
            <p class="page-subtitle">Gerencie os pedidos de compra</p>
        </div>
        <button class="btn btn-primary btn-new" @onclick="NovoPedido">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Novo Pedido
        </button>
    </div>

    @if (isLoading)
    {
        <div class="loading-container">
            <div class="spinner-large"></div>
            <p>Carregando pedidos...</p>
        </div>
    }
    else
    {
        <div class="stats-grid">
            <div class="stat-card stat-primary">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@pedidos.Count</span>
                    <span class="stat-label">Total de Pedidos</span>
                </div>
            </div>
            <div class="stat-card stat-warning">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@pedidos.Count(p => !p.Aprovado)</span>
                    <span class="stat-label">Pendentes</span>
                </div>
            </div>
            <div class="stat-card stat-success">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@pedidos.Count(p => p.Aprovado)</span>
                    <span class="stat-label">Aprovados</span>
                </div>
            </div>
            <div class="stat-card stat-info">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@pedidos.Sum(p => p.ValorTotal).ToString("C2")</span>
                    <span class="stat-label">Valor Total</span>
                </div>
            </div>
        </div>

        <div class="table-section">
                <div class="table-card">
                    <div class="table-header">
                        <h3 class="table-title">Todos os Pedidos</h3>
                        <div class="table-search">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                            <input type="text" placeholder="Buscar pedido..." @bind="searchTerm" @oninput="OnSearch" />
                        </div>
                    </div>
                    <div class="table-container">
                        <table class="data-table">
                        <thead>
                            <tr>
                                <th>Numero</th>
                                <th>Descricao</th>
                                <th>Fornecedor</th>
                                <th>Produto</th>
                                <th>Quantidade</th>
                                <th>Valor Total</th>
                                <th>Status</th>
                                <th>Data</th>
                                <th>Acoes</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pedido in filteredPedidos)
                            {
                                <tr>
                                    <td class="cell-sku">@pedido.NumeroPedido</td>
                                    <td>
                                        <div class="cell-name">
                                            <div class="name-info">
                                                <span class="name-primary">@pedido.Descricao</span>
                                                @if (!string.IsNullOrEmpty(pedido.Observacao))
                                                {
                                                    <span class="name-secondary">@pedido.Observacao</span>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td class="cell-fornecedor">@(pedido.Fornecedor?.Nome ?? "-")</td>
                                    <td class="cell-produto">@(pedido.Produto?.Descricao ?? "-")</td>
                                    <td class="cell-quantidade">@pedido.Quantidade @GetUnidadeLabel(pedido.Unidade)</td>
                                    <td class="cell-price">@pedido.ValorTotal.ToString("C2")</td>
                                    <td>
                                        <span class="status-badge @GetStatusCssClass(pedido.Aprovado)">
                                            @(pedido.Aprovado ? "Aprovado" : "Pendente")
                                        </span>
                                    </td>
                                    <td class="cell-date">@pedido.DataPedido.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <div class="action-buttons">
                                            <button class="btn-action btn-edit" @onclick="() => EditarPedido(pedido)" title="Editar">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                            </button>
                                            @if (!pedido.Aprovado)
                                            {
                                                <button class="btn-action btn-approve" @onclick="() => ConfirmarAprovar(pedido)" title="Aprovar">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                                </button>
                                            }
                                            <button class="btn-action btn-delete" @onclick="() => ConfirmarDelete(pedido)" title="Excluir">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!filteredPedidos.Any())
                            {
                                <tr>
                                    <td colspan="9" class="empty-row">
                                        <div class="empty-table">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                                            <p>Nenhum pedido encontrado</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                </div>
            </div>
      
    }

    @if (showDeleteModal)
    {
        <div class="modal-overlay" @onclick="CancelarDelete">
            <div class="modal-content" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h3>Confirmar Exclusao</h3>
                    <button class="modal-close" @onclick="CancelarDelete">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </div>
                <div class="modal-body">
                    <p>Tem certeza que deseja excluir o pedido "<strong>@pedidoParaExcluir?.NumeroPedido</strong>"?</p>
                    <p class="warning-text">Esta acao e permanente e nao pode ser desfeita.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelarDelete">Cancelar</button>
                    <button class="btn btn-danger" @onclick="ExcluirPedido">Excluir</button>
                </div>
            </div>
        </div>
    }

    @if (showAprovarModal)
    {
        <div class="modal-overlay" @onclick="CancelarAprovar">
            <div class="modal-content" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h3>Aprovar Pedido</h3>
                    <button class="modal-close" @onclick="CancelarAprovar">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </div>
                <div class="modal-body">
                    <p>Para aprovar o pedido <strong>@pedidoParaAprovar?.NumeroPedido</strong>, informe seu email:</p>
                    <div class="form-group">
                        <label for="emailAprovacao">Email</label>
                        <input type="email" id="emailAprovacao" @bind="emailAprovacao" placeholder="seu@email.com" class="form-input" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelarAprovar">Cancelar</button>
                    <button class="btn btn-success" @onclick="AprovarPedido">Aprovar</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<PedidoCompra> pedidos = new();
    private List<PedidoCompra> filteredPedidos = new();
    private bool isLoading = true;
    private string searchTerm = string.Empty;
    private bool showDeleteModal = false;
    private PedidoCompra? pedidoParaExcluir;
    private bool showAprovarModal = false;
    private PedidoCompra? pedidoParaAprovar;
    private string emailAprovacao = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await CarregarPedidos();
    }

    private async Task CarregarPedidos()
    {
        isLoading = true;
        try
        {
            pedidos = await PedidoComprasService.GetAllAsync();
            filteredPedidos = pedidos;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar pedidos: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnSearch()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredPedidos = pedidos;
        }
        else
        {
            filteredPedidos = pedidos.Where(p =>
                p.NumeroPedido.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                p.Descricao.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                (p.Fornecedor?.Nome.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (p.Produto?.Descricao.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
            ).ToList();
        }
    }

private async Task NovoPedido()
    {
        await WinBoxService.OpenWindow("pedidosCompras-edit-nova", "Novo Pedido de Compra", "/pedidoscompras/nova", 800, 700);
    }

    private async Task EditarPedido(PedidoCompra pedido)
    {
        await WinBoxService.OpenWindow($"pedidosCompras-edit-{pedido.Id}", "Editar Pedido de Compra", $"/pedidoscompras/{pedido.Id}", 800, 700);
    }

    private void ConfirmarDelete(PedidoCompra pedido)
    {
        pedidoParaExcluir = pedido;
        showDeleteModal = true;
    }

    private void CancelarDelete()
    {
        showDeleteModal = false;
        pedidoParaExcluir = null;
    }

    private async Task ExcluirPedido()
    {
        if (pedidoParaExcluir != null)
        {
            try
            {
                await PedidoComprasService.DeleteAsync(pedidoParaExcluir.Id);
                await CarregarPedidos();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Erro ao excluir pedido: {ex.Message}");
            }
        }
        showDeleteModal = false;
        pedidoParaExcluir = null;
    }

    private void ConfirmarAprovar(PedidoCompra pedido)
    {
        pedidoParaAprovar = pedido;
        emailAprovacao = string.Empty;
        showAprovarModal = true;
    }

    private void CancelarAprovar()
    {
        showAprovarModal = false;
        pedidoParaAprovar = null;
        emailAprovacao = string.Empty;
    }

    private async Task AprovarPedido()
    {
        if (pedidoParaAprovar != null && !string.IsNullOrWhiteSpace(emailAprovacao))
        {
            try
            {
                await PedidoComprasService.AprovarAsync(pedidoParaAprovar.Id, emailAprovacao);
                await CarregarPedidos();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Erro ao aprovar pedido: {ex.Message}");
            }
        }
        showAprovarModal = false;
        pedidoParaAprovar = null;
        emailAprovacao = string.Empty;
    }

    private string GetStatusCssClass(bool aprovado) => aprovado ? "badge-success" : "badge-warning";

    private string GetUnidadeLabel(UnidadeMedida unidade) => unidade switch
    {
        UnidadeMedida.UN => "un",
        UnidadeMedida.KG => "kg",
        UnidadeMedida.PC => "pc",
        UnidadeMedida.CX => "cx",
        UnidadeMedida.MT => "m",
        _ => "-"
    };
}