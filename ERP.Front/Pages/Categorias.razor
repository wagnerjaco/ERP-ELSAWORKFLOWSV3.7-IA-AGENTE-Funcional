@page "/categorias"
@inject CategoriasService CategoriasService
@inject NavigationManager Navigation
@inject WinBoxService WinBoxService

<PageTitle>Categorias - ERP</PageTitle>

<div class="categorias-page window-content">
    <div class="page-header">
        <div class="header-content">
            <h1 class="page-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                Categorias
            </h1>
            <p class="page-subtitle">Gerencie as categorias de produtos, servicos e materia-prima</p>
        </div>
        <button class="btn btn-primary btn-new" @onclick="NovaCategoria">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Nova Categoria
        </button>
    </div>

    @if (isLoading)
    {
        <div class="loading-container">
            <div class="spinner-large"></div>
            <p>Carregando categorias...</p>
        </div>
    }
    else
    {
        <div class="stats-grid">
            <div class="stat-card stat-primary">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@categorias.Count</span>
                    <span class="stat-label">Total de Categorias</span>
                </div>
            </div>
            <div class="stat-card stat-success">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@categorias.Count(c => c.Ativa)</span>
                    <span class="stat-label">Ativas</span>
                </div>
            </div>
            <div class="stat-card stat-warning">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@categorias.Count(c => c.Tipo == TipoCategoria.PRODUTO)</span>
                    <span class="stat-label">Produtos</span>
                </div>
            </div>
            <div class="stat-card stat-info">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@categorias.Count(c => c.Tipo == TipoCategoria.SERVICO)</span>
                    <span class="stat-label">Servicos</span>
                </div>
            </div>
        </div>

        <div class="content-grid">
            <div class="chart-section">
                <div class="chart-card">
                    <h3 class="chart-title">Distribuicao por Tipo</h3>
                    <div class="chart-container">
                        <div class="donut-chart">
                            <svg viewBox="0 0 100 100" class="donut">
                                @{
                                    var produtoCount = categorias.Count(c => c.Tipo == TipoCategoria.PRODUTO);
                                    var servicoCount = categorias.Count(c => c.Tipo == TipoCategoria.SERVICO);
                                    var materiaCount = categorias.Count(c => c.Tipo == TipoCategoria.MATERIA_PRIMA);
                                    var total = categorias.Count;
                                    if (total > 0)
                                    {
                                        var produtoPct = produtoCount * 100.0 / total;
                                        var servicoPct = servicoCount * 100.0 / total;
                                        var materiaPct = materiaCount * 100.0 / total;
                                        var produtoDash = produtoPct * 2.51327;
                                        var servicoDash = servicoPct * 2.51327;
                                        <circle cx="50" cy="50" r="40" fill="none" stroke="#3b82f6" stroke-width="12" stroke-dasharray="@produtoDash 251.327" stroke-dashoffset="62.83" />
                                        <circle cx="50" cy="50" r="40" fill="none" stroke="#10b981" stroke-width="12" stroke-dasharray="@servicoDash 251.327" stroke-dashoffset="@(62.83 - produtoDash)" />
                                        <circle cx="50" cy="50" r="40" fill="none" stroke="#f59e0b" stroke-width="12" stroke-dasharray="@materiaPct 251.327" stroke-dashoffset="@(62.83 - produtoDash - servicoDash)" />
}
}
                            </svg>
                            <div class="chart-center">
                                <span class="chart-total">@categorias.Count</span>
                                <span class="chart-label">Total</span>
                            </div>
                        </div>
                        <div class="chart-legend">
                            <div class="legend-item">
                                <span class="legend-color" style="background: #3b82f6;"></span>
                                <span class="legend-text">Produtos</span>
                                <span class="legend-value">@produtoCount</span>
                            </div>
                            <div class="legend-item">
                                <span class="legend-color" style="background: #10b981;"></span>
                                <span class="legend-text">Servicos</span>
                                <span class="legend-value">@servicoCount</span>
                            </div>
                            <div class="legend-item">
                                <span class="legend-color" style="background: #f59e0b;"></span>
                                <span class="legend-text">Materia Prima</span>
                                <span class="legend-value">@materiaCount</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="recent-card">
                    <h3 class="chart-title">Recentemente Adicionadas</h3>
                    <div class="recent-list">
                        @foreach (var categoria in categorias.OrderByDescending(c => c.CreatedAt).Take(5))
                        {
                            <div class="recent-item">
                                <div class="recent-icon" style="background: @GetTipoColor(categoria.Tipo)20; color: @GetTipoColor(categoria.Tipo);">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                                </div>
                                <div class="recent-content">
                                    <span class="recent-name">@categoria.Nome</span>
                                    <span class="recent-date">@categoria.CreatedAt.ToString("dd/MM/yyyy")</span>
                                </div>
                                <span class="recent-badge" style="background: @GetTipoColor(categoria.Tipo)20; color: @GetTipoColor(categoria.Tipo);">
                                    @GetTipoLabel(categoria.Tipo)
                                </span>
                            </div>
                        }
                        @if (!categorias.Any())
                        {
                            <div class="empty-state">
                                <p>Nenhuma categoria cadastrada</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="table-section">
                <div class="table-card">
                    <div class="table-header">
                        <h3 class="table-title">Todas as Categorias</h3>
                        <div class="table-search">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                            <input type="text" placeholder="Buscar categoria..." @bind="searchTerm" @oninput="OnSearch" />
                        </div>
                    </div>
                    <div class="table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Nome</th>
                                    <th>Tipo</th>
                                    <th>Descricao</th>
                                    <th>Status</th>
                                    <th>Acoes</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var categoria in filteredCategorias)
                                {
                                    <tr>
                                        <td>
                                            <div class="cell-name">
                                                <div class="name-icon" style="background: @GetTipoColor(categoria.Tipo)20; color: @GetTipoColor(categoria.Tipo);">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                                                </div>
                                                @categoria.Nome
                                            </div>
                                        </td>
                                        <td>
                                            <span class="type-badge" style="background: @GetTipoColor(categoria.Tipo)20; color: @GetTipoColor(categoria.Tipo);">
                                                @GetTipoLabel(categoria.Tipo)
                                            </span>
                                        </td>
                                        <td class="cell-desc">@categoria.Descricao</td>
                                        <td>
                                            <span class="status-badge @(categoria.Ativa ? "status-active" : "status-inactive")">
                                                @(categoria.Ativa ? "Ativa" : "Inativa")
                                            </span>
                                        </td>
                                        <td>
                                            <div class="action-buttons">
                                                <button class="btn-action btn-edit" @onclick="() => EditarCategoria(categoria)" title="Editar">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                                </button>
                                                <button class="btn-action btn-delete" @onclick="() => ConfirmarDelete(categoria)" title="Excluir">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                @if (!filteredCategorias.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="empty-row">
                                            <div class="empty-table">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
                                                <p>Nenhuma categoria encontrada</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (showDeleteModal)
    {
        <div class="modal-overlay" @onclick="CancelarDelete">
            <div class="modal-content" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h3>Confirmar Exclusao</h3>
                    <button class="modal-close" @onclick="CancelarDelete">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </div>
                <div class="modal-body">
                    <p>Tem certeza que deseja excluir a categoria "<strong>@categoriaParaExcluir?.Nome</strong>"?</p>
                    <p class="warning-text">Esta acao nao podera ser desfeita.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelarDelete">Cancelar</button>
                    <button class="btn btn-danger" @onclick="ExcluirCategoria">Excluir</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Categoria> categorias = new();
    private List<Categoria> filteredCategorias = new();
    private bool isLoading = true;
    private string searchTerm = string.Empty;
    private bool showDeleteModal = false;
    private Categoria? categoriaParaExcluir;

    protected override async Task OnInitializedAsync()
    {
        await CarregarCategorias();
    }

    private async Task CarregarCategorias()
    {
        isLoading = true;
        try
        {
            categorias = await CategoriasService.GetAllAsync();
            filteredCategorias = categorias;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar categorias: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnSearch()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredCategorias = categorias;
        }
        else
        {
            filteredCategorias = categorias.Where(c =>
                c.Nome.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                (c.Descricao?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                GetTipoLabel(c.Tipo).Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
            ).ToList();
        }
    }

    private async Task NovaCategoria()
    {
        await WinBoxService.OpenWindow("categoria-edit-nova", "Nova Categoria", "/categorias/nova", 600, 500);
    }

    private async Task EditarCategoria(Categoria categoria)
    {
        await WinBoxService.OpenWindow($"categoria-edit-{categoria.Id}", "Editar Categoria", $"/categorias/{categoria.Id}", 600, 500);
    }

    private void ConfirmarDelete(Categoria categoria)
    {
        categoriaParaExcluir = categoria;
        showDeleteModal = true;
    }

    private void CancelarDelete()
    {
        showDeleteModal = false;
        categoriaParaExcluir = null;
    }

    private async Task ExcluirCategoria()
    {
        if (categoriaParaExcluir != null)
        {
            try
            {
                await CategoriasService.DeleteAsync(categoriaParaExcluir.Id);
                await CarregarCategorias();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Erro ao excluir categoria: {ex.Message}");
            }
        }
        showDeleteModal = false;
        categoriaParaExcluir = null;
    }

    private string GetTipoColor(TipoCategoria tipo) => tipo switch
    {
        TipoCategoria.PRODUTO => "#3b82f6",
        TipoCategoria.SERVICO => "#10b981",
        TipoCategoria.MATERIA_PRIMA => "#f59e0b",
        _ => "#6b7280"
    };

    private string GetTipoLabel(TipoCategoria tipo) => tipo switch
    {
        TipoCategoria.PRODUTO => "Produto",
        TipoCategoria.SERVICO => "Servico",
        TipoCategoria.MATERIA_PRIMA => "Materia Prima",
        _ => "Desconhecido"
    };
}