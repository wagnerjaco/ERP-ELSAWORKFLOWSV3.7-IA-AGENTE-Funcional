@page "/pedidoscompras/{Id:guid?}"
@page "/pedidoscompras/nova"
@page "/pedidoscompras/novo-produto"
@using ERP.Front.Models
@using Microsoft.JSInterop
@inject PedidoComprasService PedidoComprasService
@inject FornecedoresService FornecedoresService
@inject ProdutosService ProdutosService
@inject CategoriasService CategoriasService
@inject MarcasService MarcasService
@inject WinBoxService WinBoxService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>@(IsEditMode ? "Editar Pedido" : "Novo Pedido de Compra") - ERP</PageTitle>

<div class="pedidos-page">
    <div class="page-header">
        <div class="header-content">
            <h1 class="page-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    @if (IsEditMode)
                    {
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    }
                    else
                    {
                        <line x1="12" y1="5" x2="12" y2="19"/>
                        <line x1="5" y1="12" x2="19" y2="12"/>
                    }
                </svg>
                @(IsEditMode ? "Editar Pedido de Compra" : "Novo Pedido de Compra")
            </h1>
            <p class="page-subtitle">@(IsEditMode ? "Atualize as informacoes do pedido" : "Preencha os dados para criar um novo pedido de compra")</p>
        </div>
    </div>

    <div class="form-pedidos-container form-container-xl">
        <div class="form-card">
            <EditForm Model="pedidoForm" OnValidSubmit="Salvar">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="tab-content">
                    <div class="form-section">
                        <h3 class="form-section-title">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                            Identificacao
                        </h3>
                        <div class="form-grid">
                            <div class="form-group">
                                <label for="numero">Numero do Pedido</label>
                                <div class="input-wrapper">
                                    <InputText id="numero" @bind-Value="pedidoForm.NumeroPedido" placeholder="PC-000001" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="data">Data do Pedido</label>
                                <div class="input-wrapper">
                                    <InputDate id="data" @bind-Value="pedidoForm.DataPedido" />
                                </div>
                            </div>
                            <div class="form-group full-width">
                                <label for="descricao">Descricao *</label>
                                <div class="input-wrapper">
                                    <InputText id="descricao" @bind-Value="pedidoForm.Descricao" placeholder="Descricao do pedido" />
                                </div>
                                <ValidationMessage For="@(() => pedidoForm.Descricao)" />
                            </div>
                        </div>
                    </div>

                    <div class="form-section">
                        <h3 class="form-section-title">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                            Fornecedor e Produto
                        </h3>
                        <div class="form-grid">
                            <div class="form-group">
                                <label for="fornecedor">Fornecedor *</label>
                                <div class="input-wrapper select-wrapper">
                                    <InputSelect id="fornecedor" @bind-Value="pedidoForm.FornecedorId">
                                        <option value="@Guid.Empty">Selecione</option>
                                        @foreach (var fornecedor in fornecedores)
                                        {
                                            <option value="@fornecedor.Id">@fornecedor.Nome</option>
                                        }
                                    </InputSelect>
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="produto">Produto</label>
                                <div class="input-wrapper select-wrapper">
                                    <InputSelect id="produto" @bind-Value="pedidoForm.ProdutoId">
                                        <option value="@Guid.Empty">Selecione</option>
                                        @foreach (var produto in produtos)
                                        {
                                            <option value="@produto.Id">@produto.Descricao</option>
                                        }
                                    </InputSelect>
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="categoria">Categoria</label>
                                <div class="input-wrapper select-wrapper">
                                    <InputSelect id="categoria" @bind-Value="pedidoForm.CategoriaId">
                                        <option value="@Guid.Empty">Selecione</option>
                                        @foreach (var categoria in categorias)
                                        {
                                            <option value="@categoria.Id">@categoria.Nome</option>
                                        }
                                    </InputSelect>
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="marca">Marca</label>
                                <div class="input-wrapper select-wrapper">
                                    <InputSelect id="marca" @bind-Value="pedidoForm.MarcaId">
                                        <option value="@Guid.Empty">Selecione</option>
                                        @foreach (var marca in marcas)
                                        {
                                            <option value="@marca.Id">@marca.Nome</option>
                                        }
                                    </InputSelect>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="form-section">
                        <h3 class="form-section-title">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                            Valores e Quantidade
                        </h3>
                        <div class="form-grid form-grid-4">
                            <div class="form-group">
                                <label for="tipo">Tipo</label>
                                <div class="input-wrapper select-wrapper">
                                    <InputSelect id="tipo" @bind-Value="pedidoForm.Tipo">
                                        <option value="@TipoProduto.MERCADORIA">Mercadoria</option>
                                        <option value="@TipoProduto.MATERIA_PRIMA">Materia Prima</option>
                                        <option value="@TipoProduto.PRODUTO_ACABADO">Produto Acabado</option>
                                        <option value="@TipoProduto.EMBALAGEM">Embalagem</option>
                                        <option value="@TipoProduto.USO_CONSUMO">Uso e Consumo</option>
                                    </InputSelect>
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="unidade">Unidade</label>
                                <div class="input-wrapper select-wrapper">
                                    <InputSelect id="unidade" @bind-Value="pedidoForm.Unidade">
                                        <option value="@UnidadeMedida.UN">Unidade</option>
                                        <option value="@UnidadeMedida.KG">Kg</option>
                                        <option value="@UnidadeMedida.PC">Peca</option>
                                        <option value="@UnidadeMedida.CX">Caixa</option>
                                        <option value="@UnidadeMedida.MT">Metro</option>
                                    </InputSelect>
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="quantidade">Quantidade</label>
                                <div class="input-wrapper">
                                    <InputNumber id="quantidade" @bind-Value="pedidoForm.Quantidade" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="custo">Custo Medio</label>
                                <div class="input-wrapper">
                                    <span class="input-prefix">R$</span>
                                    <InputNumber id="custo" @bind-Value="pedidoForm.CustoMedio" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="valorTotal">Valor Total</label>
                                <div class="input-wrapper">
                                    <span class="input-prefix">R$</span>
                                    <InputNumber id="valorTotal" @bind-Value="pedidoForm.ValorTotal" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="emailAprovacao">Email para Aprovacao *</label>
                                <div class="input-wrapper">
                                    <InputText id="emailAprovacao" @bind-Value="pedidoForm.EmailAprovacao" placeholder="email@exemplo.com" />
                                </div>
                                <ValidationMessage For="@(() => pedidoForm.EmailAprovacao)" />
                            </div>
                            <div class="form-group checkbox-group">
                                <label class="checkbox-label">
                                    <InputCheckbox @bind-Value="pedidoForm.Ativa" />
                                    <span>Ativo</span>
                                </label>
                            </div>
                        </div>
                    </div>
                    <div class="form-section">
                        <h3 class="form-section-title">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="17" y1="10" x2="3" y2="10"/><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="14" x2="3" y2="14"/><line x1="17" y1="18" x2="3" y2="18"/></svg>
                            Observacoes
                        </h3>
                        <div class="form-group full-width">
                            <div class="input-wrapper textarea-wrapper">
                                <InputTextArea id="observacao" @bind-Value="pedidoForm.Observacao" placeholder="Observacoes adicionais..." rows="3" />
                            </div>
                        </div>
                    </div>
                </div>
            </EditForm>
        </div>

        <div class="preview-card">
            <h3 class="preview-title">Resumo do Pedido</h3>
            <div class="preview-content">
                <div class="preview-item">
                    <span class="preview-label">Numero</span>
                    <span class="preview-value">@(!string.IsNullOrEmpty(pedidoForm.NumeroPedido) ? pedidoForm.NumeroPedido : "-")</span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Descricao</span>
                    <span class="preview-value">@(!string.IsNullOrEmpty(pedidoForm.Descricao) ? pedidoForm.Descricao : "-")</span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Fornecedor</span>
                    <span class="preview-value">@(fornecedores.FirstOrDefault(f => f.Id == pedidoForm.FornecedorId)?.Nome ?? "-")</span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Quantidade</span>
                    <span class="preview-value">@pedidoForm.Quantidade @GetUnidadeLabel(pedidoForm.Unidade)</span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Valor Total</span>
                    <span class="preview-value preview-price">@pedidoForm.ValorTotal.ToString("C2")</span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Data</span>
                    <span class="preview-value">@pedidoForm.DataPedido.ToString("dd/MM/yyyy")</span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Status</span>
                    <span class="preview-badge @(pedidoForm.Ativa ? "badge-active" : "badge-inactive")">
                        @(pedidoForm.Ativa ? "Ativo" : "Inativo")
                    </span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Aprovacao</span>
                    <span class="preview-badge @(pedidoForm.Aprovado ? "badge-success" : "badge-warning")">
                        @(pedidoForm.Aprovado ? "Aprovado" : "Pendente")
                    </span>
                </div>
                @if (!string.IsNullOrEmpty(pedidoForm.EmailAprovacao))
                {
                    <div class="preview-item">
                        <span class="preview-label">Email Aprovacao</span>
                        <span class="preview-value">@pedidoForm.EmailAprovacao</span>
                    </div>
                }
            </div>
            <div class="form-actions-bottom">
                <button type="button" class="btn btn-primary" disabled="@isSaving" @onclick="Salvar">
                    @if (isSaving)
                    {
                        <span class="spinner"></span>
                        @(IsEditMode ? "Salvando..." : "Criando...")
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                        @(IsEditMode ? "Salvar Alteracoes" : "Criar Pedido")
                    }
                </button>
            </div>
        </div>
       
    </div>

    

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-error">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            @errorMessage
        </div>
    }

    @if (showSuccessToast)
    {
        <div class="alert alert-success">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            Pedido criado com sucesso! Modo de edição ativado.
        </div>
    }

    @if (showResultModal)
    {
        <div class="modal-overlay" @onclick="FecharResultModal">
            <div class="modal-content" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h3>
                        @if (isSuccess)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        }
                        @(isSuccess ? "Sucesso" : "Erro")
                    </h3>
                </div>
                <div class="modal-body">
                    <p>@resultMessage</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="FecharResultModal">OK</button>
                </div>
            </div>
        </div>
    }
</div>

@code {

    [Parameter]
    public Guid? Id { get; set; }

    private PedidoCompraForm pedidoForm = new();
    private Guid? produtoIdFromNotification;
    private bool isSaving = false;
    private string errorMessage = string.Empty;
    private bool showSuccessToast = false;
    private bool modoEdicaoForcado = false;
    private bool showResultModal = false;
    private bool isSuccess = false;
    private string resultMessage = string.Empty;

    private List<Fornecedor> fornecedores = new();
    private List<Produto> produtos = new();
    private List<Categoria> categorias = new();
    private List<Marca> marcas = new();

    private bool IsEditMode => modoEdicaoForcado || (Id.HasValue && Id != Guid.Empty);

    protected override async Task OnInitializedAsync()
    {
        var taskFornecedores = FornecedoresService.GetAllAsync();
        var taskProdutos = ProdutosService.GetAllAsync();
        var taskCategorias = CategoriasService.GetAllAsync();
        var taskMarcas = MarcasService.GetAllAsync();

        await Task.WhenAll(taskFornecedores, taskProdutos, taskCategorias, taskMarcas);

        fornecedores = await taskFornecedores;
        produtos = await taskProdutos;
        categorias = await taskCategorias;
        marcas = await taskMarcas;

        await VerificarProdutoIdNaUrl();

        if (!IsEditMode && produtoIdFromNotification == null)
        {
            pedidoForm.NumeroPedido = GerarNumeroPedido();
        }

        if (IsEditMode && Id.HasValue)
        {
            await CarregarPedido();
        }

        WinBoxService.OnWindowClosed += OnPedidoWindowClosed;
    }

    private async Task VerificarProdutoIdNaUrl()
    {
        try
        {
            var fullUri = await JSRuntime.InvokeAsync<string>("eval", "window.location.href");
            if (fullUri.Contains("produtoId="))
            {
                var queryStart = fullUri.IndexOf("produtoId=") + 9;
                var queryEnd = fullUri.IndexOf("&", queryStart);
                if (queryEnd == -1) queryEnd = fullUri.Length;
                var produtoIdStr = fullUri.Substring(queryStart, queryEnd - queryStart);
                if (Guid.TryParse(produtoIdStr, out var pid))
                {
                    produtoIdFromNotification = pid;
                    await CarregarProdutoNoPedido();
                }
            }
        }
        catch { }
    }

    private void OnPedidoWindowClosed(string windowId)
    {
    }

    private string GerarNumeroPedido()
    {
        return $"PC-{DateTime.Now:yyyyMMdd}-{new Random().Next(1000, 9999)}";
    }

    private async Task CarregarPedido()
    {
        try
        {
            var pedido = await PedidoComprasService.GetByIdAsync(Id!.Value);
            if (pedido != null)
            {
                pedidoForm = new PedidoCompraForm
                {
                    NumeroPedido = pedido.NumeroPedido,
                    Descricao = pedido.Descricao,
                    Tipo = pedido.Tipo,
                    Unidade = pedido.Unidade,
                    Quantidade = pedido.Quantidade,
                    CustoMedio = pedido.CustoMedio,
                    ValorTotal = pedido.ValorTotal,
                    Observacao = pedido.Observacao,
                    DataPedido = pedido.DataPedido,
                    FornecedorId = pedido.FornecedorId,
                    CategoriaId = pedido.CategoriaId,
                    MarcaId = pedido.MarcaId,
                    ProdutoId = pedido.ProdutoId,
                    Ativa = pedido.Ativa,
                    Aprovado = pedido.Aprovado,
                    EmailAprovacao = pedido.EmailAprovacao
                };
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar pedido: {ex.Message}";
        }
    }

    private async Task CarregarProdutoNoPedido()
    {
        try
        {
            var produto = await ProdutosService.GetByIdAsync(produtoIdFromNotification!.Value);
            if (produto != null)
            {
                pedidoForm = new PedidoCompraForm
                {
                    NumeroPedido = GerarNumeroPedido(),
                    Descricao = produto.Descricao,
                    Tipo = produto.Tipo,
                    Unidade = produto.UnidadeMedida,
                    Quantidade = 0,
                    CustoMedio = produto.CustoMedio,
                    ValorTotal = 0,
                    DataPedido = DateTime.Today,
                    CategoriaId = produto.CategoriaId,
                    MarcaId = produto.MarcaId,
                    ProdutoId = produto.Id,
                    Ativa = true,
                    Aprovado = false
                };
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar produto: {ex.Message}";
        }
    }

    private async Task Salvar()
    {
        isSaving = true;
        errorMessage = string.Empty;

        try
        {
            if (pedidoForm.FornecedorId == Guid.Empty)
            {
                errorMessage = "Selecione um fornecedor.";
                isSaving = false;
                return;
            }

            PedidoCompra? result;
            if (IsEditMode && Id.HasValue)
            {
                result = await PedidoComprasService.UpdateAsync(Id!.Value, pedidoForm);
            }
            else
            {
                result = await PedidoComprasService.CreateAsync(pedidoForm);
            }

            if (result != null)
            {
                isSuccess = true;
                resultMessage = IsEditMode ? "Pedido atualizado com sucesso!" : "Pedido criado com sucesso!";
                showResultModal = true;
            }
            else
            {
                isSuccess = false;
                resultMessage = "Erro ao salvar pedido. Tente novamente.";
                showResultModal = true;
            }
        }
        catch (Exception ex)
        {
            isSuccess = false;
            resultMessage = $"Erro ao salvar: {ex.Message}";
            showResultModal = true;
        }
        finally
        {
            isSaving = false;
        }
    }

    private string GetUnidadeLabel(UnidadeMedida unidade) => unidade switch
    {
        UnidadeMedida.UN => "un",
        UnidadeMedida.KG => "kg",
        UnidadeMedida.PC => "pc",
        UnidadeMedida.CX => "cx",
        UnidadeMedida.MT => "m",
        _ => "-"
    };

    private void FecharResultModal()
    {
        showResultModal = false;
        if (isSuccess)
        {
            FecharJanela();
        }
        isSuccess = false;
        resultMessage = string.Empty;
    }

    private void FecharJanela()
    {
        var windowId = WinBoxService.Windows.Keys
            .FirstOrDefault(k => k.Contains("pedidosCompras-edit-"));
        _ = WinBoxService.CloseWindow(windowId ?? "pedidosCompras-edit-nova");
    }

    private void LimparFormulario()
    {
        pedidoForm = new PedidoCompraForm
        {
            NumeroPedido = GerarNumeroPedido(),
            DataPedido = DateTime.Today
        };
        Id = null;
        modoEdicaoForcado = false;
        showResultModal = false;
        isSuccess = false;
        resultMessage = string.Empty;
    }

    public void Dispose()
    {
        WinBoxService.OnWindowClosed -= OnPedidoWindowClosed;
    }
}