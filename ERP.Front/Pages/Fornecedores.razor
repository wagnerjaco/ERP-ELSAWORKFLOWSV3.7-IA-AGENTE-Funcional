@page "/fornecedores"
@using ERP.Front.Models
@inject FornecedoresService FornecedoresService
@inject NavigationManager Navigation
@inject WinBoxService WinBoxService

<PageTitle>Fornecedores - ERP</PageTitle>

<div class="fornecedores-page window-content">
    <div class="page-header">
        <div class="header-content">
            <h1 class="page-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                Fornecedores
            </h1>
            <p class="page-subtitle">Gerencie fornecedores pessoa fisica e juridica</p>
        </div>
        <button class="btn btn-primary btn-new" @onclick="NovoFornecedor">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Novo Fornecedor
        </button>
    </div>

    @if (isLoading)
    {
        <div class="loading-container">
            <div class="spinner-large"></div>
            <p>Carregando fornecedores...</p>
        </div>
    }
    else
    {
        <div class="stats-grid">
            <div class="stat-card stat-primary">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@fornecedores.Count</span>
                    <span class="stat-label">Total de Fornecedores</span>
                </div>
            </div>
            <div class="stat-card stat-success">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@fornecedores.Count(f => f.Situacao == SituacaoFornecedor.ATIVO)</span>
                    <span class="stat-label">Ativos</span>
                </div>
            </div>
            <div class="stat-card stat-warning">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@fornecedores.Count(f => f.Situacao == SituacaoFornecedor.INATIVO)</span>
                    <span class="stat-label">Inativos</span>
                </div>
            </div>
            <div class="stat-card stat-danger">
                <div class="stat-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                </div>
                <div class="stat-content">
                    <span class="stat-value">@fornecedores.Count(f => f.Situacao == SituacaoFornecedor.BLOQUEADO)</span>
                    <span class="stat-label">Bloqueados</span>
                </div>
            </div>
        </div>

        <div class="content-grid">
            <div class="chart-section">
                <div class="chart-card">
                    <h3 class="chart-title">Por Tipo de Pessoa</h3>
                    <div class="chart-container">
                        <div class="donut-chart">
                            <svg viewBox="0 0 100 100" class="donut">
                                @{
                                    var pfCount = fornecedores.Count(f => f.TipoPessoa == TipoPessoa.FISICA);
                                    var pjCount = fornecedores.Count(f => f.TipoPessoa == TipoPessoa.JURIDICA);
                                    var total = fornecedores.Count;
                                    if (total > 0)
                                    {
                                        var pfPct = pfCount * 100.0 / total;
                                        var pjPct = pjCount * 100.0 / total;
                                        var pfDash = pfPct * 2.51327;
                                        <circle cx="50" cy="50" r="40" fill="none" stroke="#8b5cf6" stroke-width="12" stroke-dasharray="@pfDash 251.327" stroke-dashoffset="62.83" />
                                        <circle cx="50" cy="50" r="40" fill="none" stroke="#06b6d4" stroke-width="12" stroke-dasharray="@pjPct 251.327" stroke-dashoffset="@(62.83 - pfDash)" />
                                    }
                                }
                            </svg>
                            <div class="chart-center">
                                <span class="chart-total">@fornecedores.Count</span>
                                <span class="chart-label">Total</span>
                            </div>
                        </div>
                        <div class="chart-legend">
                            <div class="legend-item">
                                <span class="legend-color" style="background: #8b5cf6;"></span>
                                <span class="legend-text">Pessoa Fisica</span>
                                <span class="legend-value">@fornecedores.Count(f => f.TipoPessoa == TipoPessoa.FISICA)</span>
                            </div>
                            <div class="legend-item">
                                <span class="legend-color" style="background: #06b6d4;"></span>
                                <span class="legend-text">Pessoa Juridica</span>
                                <span class="legend-value">@fornecedores.Count(f => f.TipoPessoa == TipoPessoa.JURIDICA)</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="chart-card">
                    <h3 class="chart-title">Por Estado (UF)</h3>
                    <div class="estado-list">
                        @foreach (var estado in fornecedores.GroupBy(f => f.Uf).OrderByDescending(g => g.Count()).Take(6))
                        {
                            <div class="estado-item">
                                <span class="estado-sigla">@(string.IsNullOrEmpty(estado.Key) ? "-" : estado.Key)</span>
                                <div class="estado-bar">
                                    <div class="estado-fill" style="width: @(fornecedores.Count > 0 ? (estado.Count() * 100.0 / fornecedores.Count) : 0)%"></div>
                                </div>
                                <span class="estado-count">@estado.Count()</span>
                            </div>
                        }
                        @if (!fornecedores.Any())
                        {
                            <div class="empty-state">
                                <p>Nenhum fornecedor cadastrado</p>
                            </div>
                        }
                    </div>
                </div>

                <div class="recent-card">
                    <h3 class="chart-title">Recentemente Adicionados</h3>
                    <div class="recent-list">
                        @foreach (var fornecedor in fornecedores.OrderByDescending(f => f.CreatedAt).Take(5))
                        {
                            <div class="recent-item">
                                <div class="recent-icon" style="background: @GetTipoPessoaColor(fornecedor.TipoPessoa)20; color: @GetTipoPessoaColor(fornecedor.TipoPessoa);">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                </div>
                                <div class="recent-content">
                                    <span class="recent-name">@fornecedor.Nome</span>
                                    <span class="recent-date">@fornecedor.CreatedAt.ToString("dd/MM/yyyy")</span>
                                </div>
                                <span class="recent-badge" style="background: @GetSituacaoColor(fornecedor.Situacao)20; color: @GetSituacaoColor(fornecedor.Situacao);">
                                    @GetSituacaoLabel(fornecedor.Situacao)
                                </span>
                            </div>
                        }
                        @if (!fornecedores.Any())
                        {
                            <div class="empty-state">
                                <p>Nenhum fornecedor cadastrado</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="table-section">
                <div class="table-card">
                    <div class="table-header">
                        <h3 class="table-title">Todos os Fornecedores</h3>
                        <div class="table-search">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                            <input type="text" placeholder="Buscar fornecedor..." @bind="searchTerm" @oninput="OnSearch" />
                        </div>
                    </div>
                    <div class="table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Nome</th>
                                    <th>Tipo</th>
                                    <th>CPF/CNPJ</th>
                                    <th>Contato</th>
                                    <th>Cidade/UF</th>
                                    <th>Status</th>
                                    <th>Acoes</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var fornecedor in filteredFornecedores)
                                {
                                    <tr>
                                        <td>
                                            <div class="cell-name">
                                                <div class="name-icon" style="background: @GetTipoPessoaColor(fornecedor.TipoPessoa)20; color: @GetTipoPessoaColor(fornecedor.TipoPessoa);">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                                </div>
                                                <div class="name-info">
                                                    <span class="name-primary">@fornecedor.Nome</span>
                                                    @if (!string.IsNullOrEmpty(fornecedor.NomeFantasia))
                                                    {
                                                        <span class="name-secondary">@fornecedor.NomeFantasia</span>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="type-badge" style="background: @GetTipoPessoaColor(fornecedor.TipoPessoa)20; color: @GetTipoPessoaColor(fornecedor.TipoPessoa);">
                                                @GetTipoPessoaLabel(fornecedor.TipoPessoa)
                                            </span>
                                        </td>
                                        <td class="cell-doc">@fornecedor.CpfCnpj</td>
                                        <td class="cell-contact">
                                            @if (!string.IsNullOrEmpty(fornecedor.Email))
                                            {
                                                <div>@fornecedor.Email</div>
                                            }
                                            @if (!string.IsNullOrEmpty(fornecedor.Telefone))
                                            {
                                                <div class="contact-phone">@fornecedor.Telefone</div>
                                            }
                                        </td>
                                        <td class="cell-city">
                                            @fornecedor.Cidade@(!string.IsNullOrEmpty(fornecedor.Uf) ? $"/{fornecedor.Uf}" : "")
                                        </td>
                                        <td>
                                            <span class="status-badge status-@GetSituacaoCssClass(fornecedor.Situacao)">
                                                @GetSituacaoLabel(fornecedor.Situacao)
                                            </span>
                                        </td>
                                        <td>
                                            <div class="action-buttons">
                                                <button class="btn-action btn-edit" @onclick="() => EditarFornecedor(fornecedor)" title="Editar">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                                </button>
                                                <button class="btn-action btn-delete" @onclick="() => ConfirmarDelete(fornecedor)" title="Excluir">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                @if (!filteredFornecedores.Any())
                                {
                                    <tr>
                                        <td colspan="7" class="empty-row">
                                            <div class="empty-table">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
                                                <p>Nenhum fornecedor encontrado</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (showDeleteModal)
    {
        <div class="modal-overlay" @onclick="CancelarDelete">
            <div class="modal-content" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h3>Confirmar Exclusao</h3>
                    <button class="modal-close" @onclick="CancelarDelete">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </div>
                <div class="modal-body">
                    <p>Tem certeza que deseja excluir o fornecedor "<strong>@fornecedorParaExcluir?.Nome</strong>"?</p>
                    <p class="warning-text">Esta acao alterara o status para inativo.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelarDelete">Cancelar</button>
                    <button class="btn btn-danger" @onclick="ExcluirFornecedor">Excluir</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Fornecedor> fornecedores = new();
    private List<Fornecedor> filteredFornecedores = new();
    private bool isLoading = true;
    private string searchTerm = string.Empty;
    private bool showDeleteModal = false;
    private Fornecedor? fornecedorParaExcluir;

    protected override async Task OnInitializedAsync()
    {
        await CarregarFornecedores();
    }

    private async Task CarregarFornecedores()
    {
        isLoading = true;
        try
        {
            fornecedores = await FornecedoresService.GetAllAsync();
            filteredFornecedores = fornecedores;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao carregar fornecedores: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnSearch()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredFornecedores = fornecedores;
        }
        else
        {
            filteredFornecedores = fornecedores.Where(f =>
                f.Nome.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                (f.NomeFantasia?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (f.CpfCnpj?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (f.Email?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (f.Cidade?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
            ).ToList();
        }
    }

    private async Task NovoFornecedor()
    {
        await WinBoxService.OpenWindow("fornecedor-edit-nova", "Novo Fornecedor", "/fornecedores/novo", 700, 600);
    }

    private async Task EditarFornecedor(Fornecedor fornecedor)
    {
        await WinBoxService.OpenWindow($"fornecedor-edit-{fornecedor.Id}", "Editar Fornecedor", $"/fornecedores/{fornecedor.Id}", 700, 600);
    }

    private void ConfirmarDelete(Fornecedor fornecedor)
    {
        fornecedorParaExcluir = fornecedor;
        showDeleteModal = true;
    }

    private void CancelarDelete()
    {
        showDeleteModal = false;
        fornecedorParaExcluir = null;
    }

    private async Task ExcluirFornecedor()
    {
        if (fornecedorParaExcluir != null)
        {
            try
            {
                await FornecedoresService.DeleteAsync(fornecedorParaExcluir.Id);
                await CarregarFornecedores();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Erro ao excluir fornecedor: {ex.Message}");
            }
        }
        showDeleteModal = false;
        fornecedorParaExcluir = null;
    }

    private string GetTipoPessoaColor(TipoPessoa tipo) => tipo switch
    {
        TipoPessoa.FISICA => "#8b5cf6",
        TipoPessoa.JURIDICA => "#06b6d4",
        _ => "#6b7280"
    };

    private string GetTipoPessoaLabel(TipoPessoa tipo) => tipo switch
    {
        TipoPessoa.FISICA => "PF",
        TipoPessoa.JURIDICA => "PJ",
        _ => "-"
    };

    private string GetSituacaoColor(SituacaoFornecedor situacao) => situacao switch
    {
        SituacaoFornecedor.ATIVO => "#10b981",
        SituacaoFornecedor.INATIVO => "#f59e0b",
        SituacaoFornecedor.BLOQUEADO => "#ef4444",
        _ => "#6b7280"
    };

    private string GetSituacaoCssClass(SituacaoFornecedor situacao) => situacao switch
    {
        SituacaoFornecedor.ATIVO => "active",
        SituacaoFornecedor.INATIVO => "warning",
        SituacaoFornecedor.BLOQUEADO => "danger",
        _ => "inactive"
    };

    private string GetSituacaoLabel(SituacaoFornecedor situacao) => situacao switch
    {
        SituacaoFornecedor.ATIVO => "Ativo",
        SituacaoFornecedor.INATIVO => "Inativo",
        SituacaoFornecedor.BLOQUEADO => "Bloqueado",
        _ => "Desconhecido"
    };
}