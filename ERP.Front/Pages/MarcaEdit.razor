@page "/marcas/{Id:guid?}"
@page "/marcas/nova"
@inject MarcasService MarcasService
@inject WinBoxService WinBoxService
@inject NavigationManager Navigation

<PageTitle>@(IsEditMode ? "Editar Marca" : "Nova Marca") - ERP</PageTitle>

<div class="form-page">
    <div class="page-header">
        <button class="btn btn-back" @onclick="Voltar" hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Voltar
        </button>
        <div class="header-content">
            <h1 class="page-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    @if (IsEditMode)
                    {
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    }
                    else
                    {
                        <line x1="12" y1="5" x2="12" y2="19"/>
                        <line x1="5" y1="12" x2="19" y2="12"/>
                    }
                </svg>
                @(IsEditMode ? "Editar Marca" : "Nova Marca")
            </h1>
            <p class="page-subtitle">@(IsEditMode ? "Atualize as informacoes da marca" : "Preencha os dados para criar uma nova marca")</p>
        </div>
    </div>

    <div class="form-container">
        <div class="form-card">
            <EditForm Model="marcaForm" OnValidSubmit="Salvar">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-grid">
                    <div class="form-group full-width">
                        <label for="nome">Nome da Marca *</label>
                        <div class="input-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                            <InputText id="nome" @bind-Value="marcaForm.Nome" placeholder="Ex: Samsung, Apple, Nike" />
                        </div>
                        <ValidationMessage For="@(() => marcaForm.Nome)" />
                    </div>

                    <div class="form-group full-width">
                        <label for="descricao">Descricao</label>
                        <div class="input-wrapper textarea-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="17" y1="10" x2="3" y2="10"/><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="14" x2="3" y2="14"/><line x1="17" y1="18" x2="3" y2="18"/></svg>
                            <InputTextArea id="descricao" @bind-Value="marcaForm.Descricao" placeholder="Descricao ou informacoes adicionais sobre a marca..." rows="4" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="toggle-label">
                            <span class="toggle-text">Marca Ativa</span>
                            <div class="toggle-wrapper">
                                <InputCheckbox id="ativa" @bind-Value="marcaForm.Ativa" />
                                <span class="toggle-switch"></span>
                            </div>
                        </label>
                        <p class="form-hint">Marcas ativas aparecem nas listagens de produtos</p>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" @onclick="Voltar" hidden="true">Cancelar</button>
                    <button type="submit" class="btn btn-primary" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner"></span>
                            @(IsEditMode ? "Salvando..." : "Criando...")
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            @(IsEditMode ? "Salvar Alteracoes" : "Criar Marca")
                        }
                    </button>
                </div>
            </EditForm>
        </div>

        <div class="preview-card">
            <h3 class="preview-title">Pre-visualizacao</h3>
            <div class="preview-content">
                <div class="preview-item">
                    <span class="preview-label">Nome</span>
                    <div class="preview-marca">
                        <span class="marca-badge" style="background: @GetMarcaColor(marcaForm.Nome)">
                            @(!string.IsNullOrEmpty(marcaForm.Nome) ? marcaForm.Nome.Substring(0, 1).ToUpper() : "?")
                        </span>
                        <span class="preview-value">@(!string.IsNullOrEmpty(marcaForm.Nome) ? marcaForm.Nome : "Nome da marca")</span>
                    </div>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Descricao</span>
                    <span class="preview-value">@(!string.IsNullOrEmpty(marcaForm.Descricao) ? marcaForm.Descricao : "Sem descricao")</span>
                </div>
                <div class="preview-item">
                    <span class="preview-label">Status</span>
                    <span class="preview-badge @(marcaForm.Ativa ? "badge-active" : "badge-inactive")">
                        @(marcaForm.Ativa ? "Ativa" : "Inativa")
                    </span>
                </div>
                @if (IsEditMode)
                {
                    <div class="preview-item">
                        <span class="preview-label">ID</span>
                        <span class="preview-value preview-id">@Id?.ToString("N").Substring(0, 8)...</span>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-error">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            @errorMessage
        </div>
    }

    @if (showResultModal)
    {
        <div class="modal-overlay" @onclick="FecharResultModal">
            <div class="modal-content" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h3>
                        @if (isSuccess)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        }
                        @(isSuccess ? "Sucesso" : "Erro")
                    </h3>
                </div>
                <div class="modal-body">
                    <p>@resultMessage</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="FecharResultModal">OK</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid? Id { get; set; }

    private MarcaForm marcaForm = new();
    private bool isSaving = false;
    private string errorMessage = string.Empty;
    private bool showResultModal = false;
    private bool isSuccess = false;
    private string resultMessage = string.Empty;

    private bool IsEditMode => Id.HasValue && Id != Guid.Empty;

    private readonly string[] brandColors = { "#3b82f6", "#10b981", "#8b5cf6", "#f59e0b", "#ef4444", "#06b6d4", "#ec4899", "#84cc16" };

    protected override async Task OnInitializedAsync()
    {
        if (IsEditMode && Id.HasValue)
        {
            await CarregarMarca();
        }
    }

    private async Task CarregarMarca()
    {
        try
        {
            var marca = await MarcasService.GetByIdAsync(Id!.Value);
            if (marca != null)
            {
                marcaForm = new MarcaForm
                {
                    Nome = marca.Nome,
                    Descricao = marca.Descricao,
                    Ativa = marca.Ativa
                };
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar marca: {ex.Message}";
        }
    }

    private async Task Salvar()
    {
        isSaving = true;
        errorMessage = string.Empty;

        try
        {
            Marca? result;
            if (IsEditMode && Id.HasValue)
            {
                result = await MarcasService.UpdateAsync(Id!.Value, marcaForm);
            }
            else
            {
                result = await MarcasService.CreateAsync(marcaForm);
            }

            if (result != null)
            {
                isSuccess = true;
                resultMessage = IsEditMode ? "Marca atualizada com sucesso!" : "Marca criada com sucesso!";
                showResultModal = true;
            }
            else
            {
                isSuccess = false;
                resultMessage = "Erro ao salvar marca. Tente novamente.";
                showResultModal = true;
            }
        }
        catch (Exception ex)
        {
            isSuccess = false;
            resultMessage = $"Erro ao salvar: {ex.Message}";
            showResultModal = true;
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Voltar()
    {
        Navigation.NavigateTo("/marcas");
    }

    private string GetMarcaColor(string nome)
    {
        if (string.IsNullOrEmpty(nome)) return brandColors[0];
        var index = nome.GetHashCode() % brandColors.Length;
        if (index < 0) index += brandColors.Length;
        return brandColors[index];
    }

    private void FecharResultModal()
    {
        showResultModal = false;
        if (isSuccess)
        {
            FecharJanela();
        }
        isSuccess = false;
        resultMessage = string.Empty;
    }

    private void FecharJanela()
    {
        var windowId = WinBoxService.Windows.Keys
            .FirstOrDefault(k => k.Contains("marca-edit-"));
        _ = WinBoxService.CloseWindow(windowId ?? "marca-edit-nova");
    }

    private void LimparFormulario()
    {
        marcaForm = new MarcaForm();
        Id = null;
        showResultModal = false;
        isSuccess = false;
        resultMessage = string.Empty;
    }
}